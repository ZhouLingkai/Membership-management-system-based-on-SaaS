/* components/card-display/card-display.wxss */

.card-display-container {
  position: relative;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.15);
}

/* 背景层 */
.card-bg-layer {
  position: absolute;
  inset: 0;
  z-index: 1;
}

.card-bg-image {
  width: 100%;
  height: 100%;
}

.card-bg-gradient {
  width: 100%;
  height: 100%;
}

.card-bg-default {
  width: 100%;
  height: 100%;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

/* 蒙版层 */
.card-mask-image {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  z-index: 2;
  object-fit: fill;
}
