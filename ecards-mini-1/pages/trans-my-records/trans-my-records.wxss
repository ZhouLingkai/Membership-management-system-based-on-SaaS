/* pages/trans-my-records/trans-my-records.wxss */
.page-container {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding: 20rpx;
}

.card {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

/* 页面提示 */
.page-tip {
  background: linear-gradient(135deg, #e3f2fd 0%, #bbdefb 100%);
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  padding: 20rpx 24rpx;
}

.tip-icon {
  font-size: 36rpx;
  flex-shrink: 0;
}

.tip-text {
  font-size: 28rpx;
  color: #1565c0;
  line-height: 1.6;
  flex: 1;
}

/* 筛选区域 */
.filter-section {
  margin-bottom: 20rpx;
}

.filter-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 20rpx;
}

.filter-item {
  margin-bottom: 20rpx;
}

.filter-label {
  font-size: 30rpx;
  color: #666;
  display: block;
  margin-bottom: 12rpx;
}

.picker-view {
  background-color: #f5f5f5;
  border-radius: 8rpx;
  padding: 16rpx;
  border: 1rpx solid #e0e0e0;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.picker-arrow {
  font-size: 20rpx;
  color: #999;
}

.date-filter-row {
  display: flex;
  justify-content: space-between;
  gap: 20rpx;
}

.date-item {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.date-label {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 12rpx;
}

.date-picker {
  background-color: #f5f5f5;
  border-radius: 8rpx;
  padding: 16rpx;
  border: 1rpx solid #e0e0e0;
}

.date-text {
  font-size: 30rpx;
  color: #333;
}

.filter-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 20rpx;
}

.reset-btn-full {
  flex: 1;
  height: 80rpx;
  background-color: #f5f5f5;
  color: #666;
  border-radius: 12rpx;
  font-size: 32rpx;
  font-weight: 600;
  border: 1rpx solid #e0e0e0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.filter-btn {
  flex: 2;
  height: 80rpx;
  background: linear-gradient(135deg, #1976d2 0%, #1565c0 100%);
  color: #fff;
  border-radius: 12rpx;
  font-size: 32rpx;
  font-weight: 600;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 记录列表 */
.records-section {
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 20rpx;
  padding-left: 8rpx;
}

.empty-list {
  text-align: center;
  padding: 80rpx 0;
  color: #999;
  font-size: 32rpx;
}

.record-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.record-item {
  padding: 24rpx;
}

.record-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 6rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.record-left {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.card-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  line-height: 1.5;
  height: auto;
}

.store-name {
  font-size: 32rpx;
  color: #666;
  line-height: 1.5;
  height: auto;
}

.record-right {
  flex-shrink: 0;
}

.record-type {
  font-size: 28rpx;
  padding: 8rpx 20rpx;
  border-radius: 8rpx;
  font-weight: 500;
  display: inline-block;
  line-height: 1.4;
  height: auto;
}

.record-type.type-1 {
  background-color: #e3f2fd;
  color: #1976d2;
}

.record-type.type-2 {
  background-color: #fff3e0;
  color: #f57c00;
}

.record-body {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.amount-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.amount-label {
  font-size: 32rpx;
  color: #666;
  line-height: 1.5;
  height: auto;
}

.amount-value {
  font-size: 40rpx;
  font-weight: 600;
  line-height: 1.5;
  height: auto;
}

.amount-value.recharge {
  color: #4caf50;
}

.amount-value.consume {
  color: #f57c00;
}

.time-row {
  display: flex;
  justify-content: flex-end;
}

.time-text {
  font-size: 30rpx;
  color: #999;
  line-height: 1.5;
  height: auto;
}

/* 加载状态 */
.loading-more,
.no-more {
  text-align: center;
  padding: 40rpx 0;
  color: #999;
  font-size: 30rpx;
}
