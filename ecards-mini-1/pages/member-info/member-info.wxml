<!--pages/member-info/member-info.wxml-->
<view class="page-container">
  <!-- 头像区域 -->
  <view class="avatar-section">
    <view class="avatar-wrapper" bindtap="onAvatarTap">
      <image 
        class="avatar-image" 
        src="{{avatarUrl || '/assets/icons/default-avatar.png'}}" 
        mode="aspectFill"
      />
      <view class="avatar-edit-icon">
        <text class="iconfont">📷</text>
      </view>
    </view>
    <view class="user-name">{{userInfo.nickname || '未设置昵称'}}</view>
    <view class="user-type-tag {{userInfo.userType === 3 ? 'employee' : 'normal'}}">
      {{userInfo.userType === 3 ? '员工用户' : '普通用户'}}
    </view>
  </view>

  <!-- 用户信息列表 -->
  <view class="info-list">
    <!-- 用户昵称（可修改） -->
    <view class="info-item editable" bindtap="onInfoItemTap" data-field="nickname" data-title="修改昵称" data-value="{{userInfo.nickname}}" data-editable="{{true}}">
      <text class="info-label">昵称</text>
      <view class="info-value-row">
        <text class="info-value">{{userInfo.nickname || '未设置'}}</text>
        <text class="arrow">></text>
      </view>
    </view>

    <!-- 手机号（只读） -->
    <view class="info-item">
      <text class="info-label">手机号</text>
      <text class="info-value">{{phoneDisplay || '--'}}</text>
    </view>

    <!-- 用户头像（可点击查看/上传） -->
    <view class="info-item editable" bindtap="onAvatarItemTap" data-type="avatar">
      <text class="info-label">用户头像</text>
      <view class="info-value-row">
        <image 
          wx:if="{{userInfo.avatar}}" 
          class="info-avatar" 
          src="{{avatarUrl}}" 
          mode="aspectFill"
        />
        <text wx:else class="info-value">点击上传</text>
        <text class="arrow">></text>
      </view>
    </view>

    <!-- 会员头像（可点击查看/上传） -->
    <view class="info-item editable" bindtap="onAvatarItemTap" data-type="memberAvatar">
      <text class="info-label">会员头像</text>
      <view class="info-value-row">
        <image 
          wx:if="{{userInfo.memberAvatar}}" 
          class="info-avatar" 
          src="{{memberAvatarUrl}}" 
          mode="aspectFill"
        />
        <text wx:else class="info-value">点击上传</text>
        <text class="arrow">></text>
      </view>
    </view>

    <!-- 我的邀请码（只读） -->
    <view class="info-item" bindtap="onCopyInviteCode">
      <text class="info-label">我的邀请码</text>
      <view class="info-value-row">
        <text class="info-value invite-code">{{userInfo.inviteCode || '--'}}</text>
        <text class="copy-btn">复制</text>
      </view>
    </view>

    <!-- 邀请人邀请码（只读） -->
    <view class="info-item">
      <text class="info-label">邀请人</text>
      <text class="info-value">{{userInfo.invitedCode || '无'}}</text>
    </view>

    <!-- 注册时间（只读） -->
    <view class="info-item">
      <text class="info-label">注册时间</text>
      <text class="info-value">{{userInfo.registerTime || '--'}}</text>
    </view>

    <!-- 登录密码管理 -->
    <view class="info-item password-row">
      <text class="info-label">登录密码</text>
      <view class="password-btns">
        <view class="inline-btn secondary" bindtap="showResetModal">重置密码</view>
      </view>
    </view>
  </view>

  <!-- 退出登录按钮 -->
  <view class="logout-section">
    <button class="btn btn-danger" bindtap="handleLogout">退出登录</button>
  </view>

  <!-- 编辑信息弹窗 -->
  <view wx:if="{{showEditMask}}" class="mask" bindtap="onMaskTap">
    <view class="modal-card" catchtap="stopPropagation">
      <view class="modal-title">{{editTitle}}</view>
      <view class="modal-content">
        <input 
          class="modal-input" 
          value="{{editValue}}" 
          bindinput="onEditInput" 
          placeholder="请输入内容" 
          maxlength="50"
        />
      </view>
      <view class="modal-footer">
        <button class="modal-btn cancel" bindtap="closeEditMask">取消</button>
        <button class="modal-btn confirm" bindtap="submitEdit">确定</button>
      </view>
    </view>
  </view>

  <!-- 重置密码弹窗 -->
  <view wx:if="{{showResetMask}}" class="mask" bindtap="onMaskTap">
    <view class="modal-card" catchtap="stopPropagation">
      <view class="modal-title">重置登录密码</view>
      <view class="modal-content">
        <view class="input-row">
          <input 
            class="modal-input flex-1" 
            value="{{resetPhone}}" 
            disabled
            placeholder="手机号"
          />
        </view>
        <view class="input-row">
          <input 
            class="modal-input flex-1" 
            type="number" 
            value="{{resetCode}}" 
            bindinput="onResetInput" 
            data-field="resetCode"
            placeholder="验证码" 
            maxlength="6"
          />
          <button class="code-btn" bindtap="sendVerifyCode" disabled="{{codeCountdown > 0}}">
            {{codeCountdown > 0 ? codeCountdown + 's' : '发送'}}
          </button>
        </view>
        <input 
          class="modal-input" 
          type="password" 
          value="{{resetNewPassword}}" 
          bindinput="onResetInput" 
          data-field="resetNewPassword"
          placeholder="请输入新密码（至少8位）" 
          maxlength="50"
        />
        <input 
          class="modal-input" 
          type="password" 
          value="{{resetConfirmPassword}}" 
          bindinput="onResetInput" 
          data-field="resetConfirmPassword"
          placeholder="请再次输入新密码" 
          maxlength="50"
        />
      </view>
      <view class="modal-footer">
        <button class="modal-btn cancel" bindtap="closeResetMask">取消</button>
        <button class="modal-btn confirm" bindtap="submitPasswordReset">确定</button>
      </view>
    </view>
  </view>

  <!-- 图片查看弹窗 -->
  <view wx:if="{{showImageMask}}" class="mask" bindtap="closeImageMask">
    <view class="image-viewer" catchtap="stopPropagation">
      <image class="view-image" src="{{viewImageUrl}}" mode="widthFix"></image>
      <view class="close-icon" bindtap="closeImageMask">×</view>
    </view>
  </view>

  <!-- 头像操作弹窗 -->
  <view wx:if="{{showAvatarActionMask}}" class="mask" bindtap="closeAvatarActionMask">
    <view class="action-sheet" catchtap="stopPropagation">
      <view class="action-item" bindtap="onViewAvatar">查看大图</view>
      <view class="action-item" bindtap="onUploadAvatar">更换头像</view>
      <view class="action-item cancel" bindtap="closeAvatarActionMask">取消</view>
    </view>
  </view>

  <!-- 上传进度弹窗 -->
  <view wx:if="{{showUploadProgress}}" class="mask">
    <view class="progress-card">
      <view class="progress-title">上传中...</view>
      <progress percent="{{uploadProgress}}" stroke-width="6" activeColor="#1890ff" />
      <view class="progress-text">{{uploadProgress}}%</view>
    </view>
  </view>

  <!-- 自定义Toast组件 -->
  <custom-toast 
    id="customToast" 
    message="{{toastMessage}}" 
    type="{{toastType}}" 
    animation-type="{{toastAnimationType}}" 
    show="{{showToast}}" />
</view>
