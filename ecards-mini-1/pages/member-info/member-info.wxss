/* pages/member-info/member-info.wxss */
.page-container {
  min-height: 100vh;
  background: #f5f5f5;
  padding: 20rpx;
  padding-bottom: 40rpx;
}

/* 头像区域 */
.avatar-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 20rpx;
  background: linear-gradient(150deg, #3C8CE7 20%, #55ace6 100%);
  border-radius: 16rpx;
  margin-bottom: 20rpx;
}

.avatar-wrapper {
  position: relative;
  width: 160rpx;
  height: 160rpx;
}

.avatar-image {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  border: 4rpx solid #fff;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.2);
}

.avatar-edit-icon {
  position: absolute;
  right: 0;
  bottom: 0;
  width: 48rpx;
  height: 48rpx;
  background: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.15);
}

.avatar-edit-icon text {
  font-size: 24rpx;
}

.user-name {
  margin-top: 20rpx;
  font-size: 36rpx;
  font-weight: bold;
  color: #fff;
}

.user-type-tag {
  margin-top: 12rpx;
  padding: 6rpx 20rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
}

.user-type-tag.normal {
  background: rgba(255,255,255,0.2);
  color: #fff;
}

.user-type-tag.employee {
  background: #faad14;
  color: #fff;
}

/* 信息列表 */
.info-list {
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  margin-bottom: 20rpx;
}

.info-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 36rpx 24rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.info-item:last-child {
  border-bottom: none;
}

.info-item.editable {
  cursor: pointer;
}

.info-label {
  font-size: 34rpx;
  color: #555;
  flex-shrink: 0;
}

.info-value {
  font-size: 34rpx;
  color: #333;
}

.info-value-row {
  display: flex;
  align-items: center;
}

.info-avatar {
  width: 60rpx;
  height: 60rpx;
  border-radius: 8rpx;
  margin-right: 12rpx;
}

.arrow {
  margin-left: 12rpx;
  color: #999;
  font-size: 24rpx;
}

.invite-code {
  font-family: monospace;
  letter-spacing: 2rpx;
  color: #1890ff;
}

.copy-btn {
  margin-left: 16rpx;
  padding: 6rpx 16rpx;
  background: #e6f7ff;
  color: #1890ff;
  border-radius: 6rpx;
  font-size: 24rpx;
}

/* 密码管理行 */
.password-row {
  padding: 24rpx 24rpx;
}

.password-btns {
  display: flex;
  gap: 16rpx;
}

.inline-btn {
  padding: 12rpx 28rpx;
  border-radius: 8rpx;
  font-size: 28rpx;
  line-height: 1.2;
  text-align: center;
}

.inline-btn.primary {
  background: #1890ff;
  color: #fff;
}

.inline-btn.primary:active {
  background: #096dd9;
}

.inline-btn.secondary {
  background: #fff;
  color: #1890ff;
  border: 2rpx solid #1890ff;
}

.inline-btn.secondary:active {
  background: #e6f7ff;
}

/* 退出登录 */
.logout-section {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx 24rpx;
}

.btn {
  flex: 1;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 12rpx;
  font-size: 30rpx;
  border: none;
}

.btn-danger {
  background: linear-gradient(135deg, #ff6b6b 0%, #ee5a5a 50%, #dc4747 100%);
  color: #fff;
}

.logout-section .btn {
  width: 100%;
}

/* 遮罩层 */
.mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

/* 弹窗卡片 */
.modal-card {
  width: 600rpx;
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  max-height: 80vh;
  display: flex;
  flex-direction: column;
}

.modal-title {
  font-size: 32rpx;
  font-weight: bold;
  padding: 30rpx 24rpx;
  border-bottom: 1rpx solid #f0f0f0;
  text-align: center;
}

.modal-content {
  padding: 30rpx 24rpx;
  flex: 1;
  overflow-y: auto;
}

.modal-input {
  width: 100%;
  height: 80rpx;
  padding: 0 20rpx;
  border: 2rpx solid #d9d9d9;
  border-radius: 8rpx;
  font-size: 28rpx;
  margin-bottom: 20rpx;
  box-sizing: border-box;
}

.input-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.flex-1 {
  flex: 1;
  margin-bottom: 0;
}

.code-btn {
  height: 80rpx;
  padding: 0 24rpx;
  background: #1890ff;
  color: #fff;
  border-radius: 8rpx;
  font-size: 28rpx;
  border: none;
  white-space: nowrap;
}

.code-btn[disabled] {
  background: #ccc;
}

.modal-footer {
  display: flex;
  border-top: 1rpx solid #f0f0f0;
}

.modal-btn {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  font-size: 32rpx;
  border: none;
  border-radius: 0;
  background: #fff;
}

.modal-btn.cancel {
  color: #666;
  border-right: 1rpx solid #f0f0f0;
}

.modal-btn.confirm {
  color: #1890ff;
  font-weight: bold;
}

/* 图片查看器 */
.image-viewer {
  position: relative;
  width: 96%;
  max-width: 700rpx;
}

.view-image {
  width: 100%;
  border-radius: 16rpx;
}

.close-icon {
  position: absolute;
  top: -80rpx;
  right: 0;
  width: 60rpx;
  height: 60rpx;
  line-height: 60rpx;
  text-align: center;
  font-size: 60rpx;
  color: #fff;
  cursor: pointer;
}

/* 操作面板 */
.action-sheet {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  border-radius: 24rpx 24rpx 0 0;
  padding-bottom: env(safe-area-inset-bottom);
}

.action-item {
  height: 100rpx;
  line-height: 100rpx;
  text-align: center;
  font-size: 32rpx;
  color: #333;
  border-bottom: 1rpx solid #f0f0f0;
}

.action-item:active {
  background: #f5f5f5;
}

.action-item.cancel {
  color: #999;
  margin-top: 16rpx;
  border-top: 16rpx solid #f5f5f5;
  border-bottom: none;
}

/* 上传进度 */
.progress-card {
  width: 500rpx;
  background: #fff;
  border-radius: 16rpx;
  padding: 40rpx;
  text-align: center;
}

.progress-title {
  font-size: 32rpx;
  color: #333;
  margin-bottom: 30rpx;
}

.progress-text {
  margin-top: 16rpx;
  font-size: 28rpx;
  color: #666;
}
