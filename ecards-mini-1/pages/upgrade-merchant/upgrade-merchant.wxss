/* pages/upgrade-merchant/upgrade-merchant.wxss */

.upgrade-container {
  min-height: 100vh;
  background: linear-gradient(to bottom, #3a7bd5 0%, #00d2ff 80%);
  padding: 60rpx 30rpx;
  box-sizing: border-box;
  position: relative;
  overflow: hidden;
}

/* 顶部宣传区域 */
.header-section {
  margin-top: 40rpx;
  margin-bottom: 60rpx;
  text-align: center;
  color: #ffffff;
  position: relative;
  z-index: 1;
}

.header-text {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.header-text .title {
  font-size: 65rpx;
  font-weight: 700;
  background: linear-gradient(135deg, #ffffff 10%, #d6ecff 100%);
  margin-bottom: 10rpx;
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
}

.header-text .subtitle {
  font-size: 30rpx;
  opacity: 0.9;
}

/* 卡片容器 */
.card-container {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 20rpx 30rpx 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
}

/* Tab 栏整体样式 */
.tab-bar {
  position: relative;
  display: flex;
  border-bottom: 2rpx solid #f0f0f0;
  margin-bottom: 30rpx;
}

/* Tab 文字样式 */
.tab-item {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  font-size: 32rpx;
  color: #666666;
  transition: color 0.3s;
}

.tab-item.active {
  color: #134697;
  font-weight: 600;
}

/* 底部滑动蓝条 */
.tab-indicator {
  position: absolute;
  bottom: 0;
  left: 0;
  width: 50%;
  height: 4rpx;
  background: linear-gradient(135deg, #267cc8 0%, #3197e4 100%);
  border-radius: 2rpx;
  transition: transform 0.3s ease;
}

/* 根据 currentTab 切换位移 */
.tab-indicator.merchant {
  transform: translateX(0%);
}

.tab-indicator.quick {
  transform: translateX(100%);
}

/* 表单容器 */
.form-container {
  opacity: 0;
  transform: translateX(30rpx);
  transition: opacity 0.4s ease, transform 0.4s ease;
}

.form-container.show {
  opacity: 1;
  transform: translateX(0);
}

.form-container.hide {
  opacity: 0;
  transform: translateY(20rpx);
  max-height: 0;
  overflow: hidden;
}

/* 步骤面板 */
.step-panel {
  padding: 20rpx 0;
  /* 移除动画，防止切换时的布局跳动 */
}

/* 表单项 */
.form-item {
  margin-bottom: 32rpx;
}

.label {
  display: block;
  font-size: 28rpx;
  color: #333;
  font-weight: 600;
  margin-bottom: 20rpx;
}

/* 单选组 */
.radio-group {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.radio-item {
  display: flex;
  align-items: center;
  padding: 24rpx 30rpx;
  background: #f8f9fa;
  border-radius: 16rpx;
  border: 2rpx solid transparent;
  transition: all 0.2s;
}

.radio-item:active {
  background: #e8f4ff;
  border-color: #3197e4;
}

.radio-item text {
  margin-left: 16rpx;
  font-size: 28rpx;
  color: #333;
}

/* 单选按钮主题色 */
radio .wx-radio-input.wx-radio-input-checked {
  background-color: #3197e4 !important;
  border-color: #3197e4 !important;
}

radio .wx-radio-input.wx-radio-input-checked::before {
  color: #ffffff !important;
}

/* 输入框 */
.input-field {
  width: 100%;
  height: 80rpx;
  padding: 0rpx 24rpx;
  background: #f8f9fa;
  border-radius: 16rpx;
  border: 2rpx solid transparent;
  font-size: 28rpx;
  color: #333;
  transition: all 0.2s;
  box-sizing: border-box;
}

.input-field:focus {
  border-color: #3197e4;
  background: #ffffff;
}

/* 上传区域 */
.upload-area {
  width: 100%;
  height: 400rpx;
  border-radius: 16rpx;
  overflow: hidden;
  background: #f8f9fa;
  border: 2rpx dashed #d0d0d0;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s;
}

.upload-area:active {
  border-color: #3197e4;
  background: #e8f4ff;
}

.upload-placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
}

.upload-icon {
  font-size: 80rpx;
  color: #999;
}

.upload-text {
  font-size: 26rpx;
  color: #999;
}

.uploaded-image {
  width: 100%;
  height: 100%;
}

/* 规则内容 */
.rules-content {
  height: 300rpx;
  padding: 30rpx;
  background: #f8f9fa;
  border-radius: 16rpx;
  margin-bottom: 30rpx;
}

.rule-item {
  display: block;
  font-size: 26rpx;
  color: #666;
  line-height: 2;
  margin-bottom: 16rpx;
}

.rule-item:last-child {
  margin-bottom: 0;
}

/* 复选框 */
.checkbox-wrapper {
  display: flex;
  align-items: center;
}

.checkbox-label {
  display: flex;
  align-items: center;
}

.checkbox-text {
  font-size: 26rpx;
  color: #666;
  margin-left: 8rpx;
}

/* 复选框主题色 */
checkbox .wx-checkbox-input.wx-checkbox-input-checked {
  background-color: #3197e4 !important;
  border-color: #3197e4 !important;
}

checkbox .wx-checkbox-input.wx-checkbox-input-checked::before {
  color: #ffffff !important;
}

/* 按钮组 */
.btn-group {
  display: flex;
  gap: 20rpx;
  margin-top: 40rpx;
}

/* 上一步按钮 */
.prev-btn {
  flex: 1;
  padding: 28rpx 0;
  background: #f0f0f0;
  color: #666;
  font-size: 30rpx;
  font-weight: 600;
  border-radius: 16rpx;
  border: none;
  transition: all 0.15s;
}

.prev-btn:active {
  transform: scale(0.98);
  background: #e0e0e0;
}

/* 下一步按钮 */
.next-btn {
  flex: 1;
  padding: 28rpx 0;
  background: linear-gradient(135deg, #267cc8 0%, #3197e4 100%);
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 600;
  border-radius: 16rpx;
  border: none;
  box-shadow: 0 4rpx 12rpx rgba(38, 124, 200, 0.3);
  transition: all 0.15s;
}

.next-btn:not([disabled]):active {
  transform: scale(0.98);
  box-shadow: 0 2rpx 8rpx rgba(38, 124, 200, 0.2);
}

.next-btn[disabled] {
  background: #cccccc;
  box-shadow: none;
  opacity: 0.6;
}

/* 提交按钮 */
.submit-btn {
  flex: 1;
  padding: 28rpx 0;
  background: linear-gradient(135deg, #267cc8 0%, #3197e4 100%);
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 600;
  border-radius: 16rpx;
  border: none;
  box-shadow: 0 4rpx 12rpx rgba(38, 124, 200, 0.3);
  transition: all 0.15s;
}

.submit-btn:not([disabled]):active {
  transform: scale(0.98);
  box-shadow: 0 2rpx 8rpx rgba(38, 124, 200, 0.2);
}

.submit-btn[disabled] {
  background: #cccccc;
  box-shadow: none;
  opacity: 0.6;
}
