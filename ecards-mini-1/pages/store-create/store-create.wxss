/* pages/store-create/store-create.wxss */

.page-container {
  min-height: 100vh;
  background: linear-gradient(180deg, #f0f4f8 0%, #e8eef3 100%);
  padding-bottom: 40rpx;
}

/* 顶部提示 */
.header-tip {
  display: flex;
  align-items: center;
  padding: 24rpx 30rpx;
  background: linear-gradient(135deg, #fff7e6 0%, #ffe7ba 100%);
  margin: 20rpx;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(250, 173, 20, 0.15);
}

.tip-icon {
  font-size: 36rpx;
  margin-right: 16rpx;
}

.tip-text {
  font-size: 26rpx;
  color: #ad6800;
  flex: 1;
}

/* 表单容器 */
.form-wrapper {
  margin: 0 20rpx;
  background: #fff;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
  overflow: hidden;
}

/* 步骤面板 */
.step-panel {
  padding: 20rpx 0;
}

.step-desc {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 30rpx;
  padding: 0 10rpx;
}

/* 表单项 */
.form-item {
  margin-bottom: 30rpx;
}

.form-label {
  font-size: 30rpx;
  color: #333;
  margin-bottom: 16rpx;
  font-weight: 500;
}

.required {
  color: #ff4d4f;
  margin-right: 6rpx;
}

.form-input {
  width: 100%;
  height: 88rpx;
  padding: 0 24rpx;
  border: 2rpx solid #e8e8e8;
  border-radius: 12rpx;
  font-size: 30rpx;
  box-sizing: border-box;
  background: #fafafa;
  transition: all 0.2s ease;
}

.form-input:focus {
  border-color: #667eea;
  background: #fff;
  box-shadow: 0 0 0 4rpx rgba(102, 126, 234, 0.1);
}

/* 地址选择 */
.address-section {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.region-picker {
  display: flex;
  justify-content: space-between;
  align-items: center;
  height: 88rpx;
  padding: 0 24rpx;
  border: 2rpx solid #e8e8e8;
  border-radius: 12rpx;
  background: #fafafa;
  font-size: 30rpx;
  color: #333;
}

.region-picker .placeholder {
  color: #bfbfbf;
}

.picker-arrow {
  color: #999;
  font-size: 24rpx;
}

.address-input {
  margin-top: 0;
}

/* 店铺类型下拉选择 */
.store-type-section {
  position: relative;
}

.store-type-input {
  padding-right: 60rpx;
}

.store-type-dropdown {
  position: absolute;
  top: 100%;
  left: 0;
  right: 0;
  background: #fff;
  border: 2rpx solid #e8e8e8;
  border-top: none;
  border-radius: 0 0 12rpx 12rpx;
  max-height: 400rpx;
  overflow-y: auto;
  z-index: 100;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.1);
}

.dropdown-item {
  padding: 24rpx;
  font-size: 30rpx;
  color: #333;
  border-bottom: 1rpx solid #f0f0f0;
}

.dropdown-item:last-child {
  border-bottom: none;
}

.dropdown-item:active {
  background: #f0f4ff;
}

/* 上传区域 */
.upload-area {
  width: 100%;
  min-height: 300rpx;
  border: 2rpx dashed #d9d9d9;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #fafafa;
  overflow: hidden;
  transition: all 0.2s ease;
}

.upload-area:active {
  border-color: #667eea;
  background: #f0f4ff;
}

.upload-placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx;
}

.upload-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.upload-text {
  font-size: 30rpx;
  color: #666;
  margin-bottom: 12rpx;
}

.upload-hint {
  font-size: 24rpx;
  color: #999;
}

.uploaded-image {
  width: 100%;
  height: 300rpx;
}

/* 单选组 */
.radio-group-inline {
  display: flex;
  gap: 20rpx;
}

.radio-item-inline {
  flex: 1;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2rpx solid #e8e8e8;
  border-radius: 12rpx;
  font-size: 30rpx;
  color: #666;
  background: #fafafa;
  transition: all 0.2s ease;
}

.radio-item-inline.active {
  border-color: #667eea;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
}

/* 日期选择器 */
.picker-view {
  display: flex;
  justify-content: space-between;
  align-items: center;
  height: 88rpx;
  padding: 0 24rpx;
  border: 2rpx solid #e8e8e8;
  border-radius: 12rpx;
  background: #fafafa;
  font-size: 30rpx;
  color: #333;
}

.picker-view .placeholder {
  color: #bfbfbf;
}

/* 按钮组 */
.btn-group {
  display: flex;
  gap: 20rpx;
  margin-top: 40rpx;
  padding-top: 30rpx;
  border-top: 1rpx solid #f0f0f0;
}

.prev-btn,
.next-btn,
.submit-btn {
  flex: 1;
  height: 96rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 16rpx;
  font-size: 32rpx;
  font-weight: 500;
  border: none;
}

.prev-btn {
  background: #f5f5f5;
  color: #666;
}

.prev-btn:active {
  background: #e8e8e8;
}

.next-btn {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
}

.next-btn:active {
  opacity: 0.9;
}

.next-btn[disabled],
.submit-btn[disabled] {
  background: #d9d9d9;
  color: #fff;
}

.submit-btn {
  background: linear-gradient(135deg, #52c41a 0%, #73d13d 100%);
  color: #fff;
}

.submit-btn:active {
  opacity: 0.9;
}

/* 遮罩层 */
.mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

/* 上传进度 */
.progress-card {
  width: 500rpx;
  background: #fff;
  border-radius: 20rpx;
  padding: 40rpx;
  text-align: center;
}

.progress-title {
  font-size: 32rpx;
  color: #333;
  margin-bottom: 30rpx;
}

.progress-text {
  margin-top: 16rpx;
  font-size: 28rpx;
  color: #666;
}
