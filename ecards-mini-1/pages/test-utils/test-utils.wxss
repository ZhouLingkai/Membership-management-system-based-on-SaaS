.container {
	padding: 16rpx;
}
.section {
	margin-bottom: 32rpx;
	padding: 16rpx;
	background: #ffffff;
	border-radius: 8rpx;
	box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}
.title {
	font-size: 30rpx;
	font-weight: 600;
	margin-bottom: 16rpx;
}
.row {
	margin-bottom: 12rpx;
}
.input {
	border: 1rpx solid #e5e5e5;
	border-radius: 6rpx;
	padding: 12rpx;
}
.btns button {
	margin-right: 12rpx;
	margin-bottom: 8rpx;
}
.result {
	color: #666;
	font-size: 26rpx;
	word-break: break-all;
}

