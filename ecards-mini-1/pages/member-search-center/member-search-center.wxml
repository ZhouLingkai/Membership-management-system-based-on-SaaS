<!--pages/member-search-center/member-search-center.wxml-->
<custom-toast id="customToast"></custom-toast>

<view class="page-container">
  <!-- 筛选区域 -->
  <view class="filter-section">
    <view class="store-info">
      <text class="store-name">{{storeName}}</text>
    </view>

    <!-- 筛选条件 - 4项一行 -->
    <view class="filter-row-4">
      <view class="filter-item-4" bindtap="openPicker" data-type="cardScope">
        <text class="filter-label">卡范围</text>
        <view class="picker-box">
          <text class="picker-text">{{cardScopeOptions[cardScopeIndex].label}}</text>
          <text class="picker-arrow">▼</text>
        </view>
      </view>
      <view class="filter-item-4" bindtap="openPicker" data-type="cardType">
        <text class="filter-label">卡种</text>
        <view class="picker-box">
          <text class="picker-text">{{cardTypeList.length > 0 && selectedCardTypeId ? selectedCardTypeName : '不限'}}</text>
          <text class="picker-arrow">▼</text>
        </view>
      </view>
      <view class="filter-item-4" bindtap="openPicker" data-type="cardTtype">
        <text class="filter-label">卡类型</text>
        <view class="picker-box">
          <text class="picker-text">{{cardTtypeOptions[cardTtypeIndex].label}}</text>
          <text class="picker-arrow">▼</text>
        </view>
      </view>
      <view class="filter-item-4" bindtap="openPicker" data-type="status">
        <text class="filter-label">状态</text>
        <view class="picker-box">
          <text class="picker-text">{{statusOptions[statusIndex].label}}</text>
          <text class="picker-arrow">▼</text>
        </view>
      </view>
    </view>

    <!-- 手机号和姓名 - 一行 -->
    <view class="filter-row-2">
      <view class="filter-item-half">
        <text class="filter-label">会员手机</text>
        <input class="filter-input" type="number" maxlength="11" placeholder="选填" value="{{filterPhone}}" bindinput="onFilterPhoneInput" />
      </view>
      <view class="filter-item-half">
        <text class="filter-label">会员姓名</text>
        <input class="filter-input" type="text" placeholder="选填" value="{{filterName}}" bindinput="onFilterNameInput" />
      </view>
    </view>

    <!-- 时间选择器 -->
    <view class="filter-row-date">
      <view class="filter-item-date">
        <text class="filter-label">开卡开始</text>
        <picker mode="date" value="{{startDate}}" bindchange="onStartDateChange">
          <view class="picker-box">
            <text class="picker-text">{{startDate || '选择日期'}}</text>
            <text class="picker-arrow">▼</text>
          </view>
        </picker>
      </view>
      <view class="filter-item-date">
        <text class="filter-label">开卡结束</text>
        <picker mode="date" value="{{endDate}}" bindchange="onEndDateChange">
          <view class="picker-box">
            <text class="picker-text">{{endDate || '选择日期'}}</text>
            <text class="picker-arrow">▼</text>
          </view>
        </picker>
      </view>
      <view class="reset-date-btn" bindtap="resetDateFilter">
        <text>重置</text>
      </view>
    </view>

    <!-- 查询按钮 -->
    <button class="search-btn" bindtap="handleSearch" disabled="{{loading}}">
      {{loading ? '查询中...' : '查询'}}
    </button>
  </view>

  <!-- 结果区域 -->
  <view class="result-section">
    <!-- 加载中 -->
    <view class="loading-state" wx:if="{{loading && !hasSearched}}">
      <text>加载中...</text>
    </view>

    <!-- 空状态 -->
    <view class="empty-state" wx:elif="{{hasSearched && cardList.length === 0}}">
      <text>暂无符合条件的会员卡</text>
    </view>

    <!-- 结果列表 -->
    <view class="result-list" wx:elif="{{cardList.length > 0}}">
      <view class="result-header">
        <text class="result-count">共{{total}}条记录</text>
      </view>

      <!-- 表格 - 单行展示 -->
      <view class="card-table">
        <view class="table-header">
          <text class="th col-name">卡种名</text>
          <text class="th col-type">卡类型</text>
          <text class="th col-phone">会员手机</text>
          <text class="th col-action">操作</text>
        </view>

        <view class="table-row" wx:for="{{cardList}}" wx:key="memberCardId">
          <text class="td col-name">{{item.cardTypeName}}</text>
          <text class="td col-type">{{item.cardTtypeName}}</text>
          <text class="td col-phone">{{item.memberPhone}}</text>
          <view class="td col-action">
            <text class="action-btn" bindtap="showCardDetail" data-card="{{item}}">详情</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 分页器 - 固定在底部 -->
  <view class="pagination" wx:if="{{hasSearched && total > 0}}">
    <view class="page-size-selector">
      <picker mode="selector" range="{{pageSizeOptions}}" range-key="label" value="{{pageSizeIndex}}" bindchange="onPageSizeChange">
        <view class="page-size-box">
          <text>{{pageSizeOptions[pageSizeIndex].label}}</text>
          <text class="arrow">▼</text>
        </view>
      </picker>
    </view>
    <view class="page-nav">
      <view class="page-btn {{pageNum <= 1 ? 'disabled' : ''}}" bindtap="prevPage">上一页</view>
      <view class="page-info">{{pageNum}}/{{totalPages}}</view>
      <view class="page-btn {{pageNum >= totalPages ? 'disabled' : ''}}" bindtap="nextPage">下一页</view>
    </view>
  </view>

  <!-- 详情弹窗 -->
  <view class="detail-modal-mask" wx:if="{{showDetailModal}}" bindtap="hideDetailModal">
    <view class="detail-modal" catchtap="">
      <view class="modal-header">
        <text class="modal-title">会员卡详情</text>
        <text class="modal-close" bindtap="hideDetailModal">×</text>
      </view>
      <scroll-view class="modal-body" scroll-y>
        <view class="detail-row">
          <text class="detail-label">卡种名称</text>
          <text class="detail-value">{{currentCard.cardTypeName}}</text>
        </view>
        <view class="detail-row">
          <text class="detail-label">卡种类型</text>
          <text class="detail-value">{{currentCard.cardTtypeName}}</text>
        </view>
        <view class="detail-row">
          <text class="detail-label">会员姓名</text>
          <text class="detail-value">{{currentCard.memberName || '-'}}</text>
        </view>
        <view class="detail-row">
          <text class="detail-label">会员手机</text>
          <text class="detail-value">{{currentCard.memberPhone}}</text>
        </view>
        <view class="detail-row">
          <text class="detail-label">店铺名称</text>
          <text class="detail-value">{{currentCard.storeName}}</text>
        </view>
        <!-- 根据卡种类型显示 -->
        <view class="detail-row" wx:if="{{currentCard.cardTtype === 1}}">
          <text class="detail-label">余额</text>
          <text class="detail-value highlight">¥{{currentCard.balance}}</text>
        </view>
        <view class="detail-row" wx:if="{{currentCard.cardTtype === 2}}">
          <text class="detail-label">剩余次数</text>
          <text class="detail-value highlight">{{currentCard.times}}次</text>
        </view>
        <view class="detail-row" wx:if="{{currentCard.cardTtype === 3}}">
          <text class="detail-label">到期时间</text>
          <text class="detail-value highlight">{{currentCard.expireDateDisplay}}</text>
        </view>
        <view class="detail-row" wx:if="{{currentCard.cardTtype === 4}}">
          <text class="detail-label">积分</text>
          <text class="detail-value highlight">{{currentCard.points}}分</text>
        </view>
        <view class="detail-row" wx:if="{{currentCard.cardTtype !== 4}}">
          <text class="detail-label">积分</text>
          <text class="detail-value">{{currentCard.points}}分</text>
        </view>
        <view class="detail-row">
          <text class="detail-label">状态</text>
          <text class="detail-value status-{{currentCard.status}}">{{currentCard.statusName}}</text>
        </view>
        <view class="detail-row">
          <text class="detail-label">开卡时间</text>
          <text class="detail-value">{{currentCard.openCardTime}}</text>
        </view>
        <view class="detail-row" wx:if="{{currentCard.activateTime}}">
          <text class="detail-label">激活时间</text>
          <text class="detail-value">{{currentCard.activateTime}}</text>
        </view>
        <view class="detail-row" wx:if="{{currentCard.originalStoreName}}">
          <text class="detail-label">办卡店铺</text>
          <text class="detail-value">{{currentCard.originalStoreName}}</text>
        </view>
      </scroll-view>
    </view>
  </view>

  <!-- 自定义选择器弹窗 -->
  <view class="picker-popup-mask {{pickerAnimating ? 'show' : ''}}" wx:if="{{showPickerPopup}}" bindtap="closePickerPopup">
    <view class="picker-popup {{pickerAnimating ? 'show' : ''}}" catchtap="">
      <view class="picker-popup-header">
        <text class="picker-popup-title">{{pickerTitle}}</text>
        <text class="picker-popup-close" bindtap="closePickerPopup">×</text>
      </view>
      
      <!-- 普通选项选择器（卡范围/卡类型/状态） -->
      <view class="picker-popup-body" wx:if="{{pickerType !== 'cardType'}}">
        <view class="picker-options">
          <view 
            class="picker-option {{(pickerType === 'cardScope' && cardScopeIndex === index) || (pickerType === 'cardTtype' && cardTtypeIndex === index) || (pickerType === 'status' && statusIndex === index) ? 'selected' : ''}}"
            wx:for="{{pickerOptions}}"
            wx:key="index"
            bindtap="selectPickerOption"
            data-index="{{index}}"
          >
            <text>{{item.label}}</text>
          </view>
        </view>
      </view>

      <!-- 卡种选择器（横向滚动+card-display） -->
      <view class="picker-popup-body card-type-body" wx:if="{{pickerType === 'cardType'}}">
        <scroll-view class="card-type-scroll" scroll-x enable-flex>
          <!-- 不限选项 -->
          <view 
            class="card-type-option {{!selectedCardTypeId ? 'selected' : ''}}"
            bindtap="selectCardTypeOption"
            data-id=""
          >
            <view class="card-type-placeholder">
              <text>不限</text>
            </view>
            <text class="card-type-name">不限卡种</text>
          </view>
          <!-- 卡种列表 -->
          <view 
            class="card-type-option {{selectedCardTypeId === item.cardTypeId ? 'selected' : ''}}"
            wx:for="{{cardTypeList}}"
            wx:key="cardTypeId"
            bindtap="selectCardTypeOption"
            data-id="{{item.cardTypeId}}"
            data-name="{{item.cardTypeName}}"
            data-item="{{item}}"
          >
            <view class="card-type-preview-wrapper">
              <card-display width="{{225}}" cardBgc="{{item.cardBgc}}" cardMask="{{item.cardMask}}" />
            </view>
            <text class="card-type-name">{{item.cardTypeName}}</text>
          </view>
        </scroll-view>
      </view>

    </view>
  </view>
</view>
