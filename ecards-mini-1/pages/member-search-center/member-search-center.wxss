/* pages/member-search-center/member-search-center.wxss */

.page-container {
  min-height: 100vh;
  background: #f5f7fa;
  padding-bottom: 140rpx;
}

/* 筛选区域 */
.filter-section {
  background: #fff;
  padding: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.store-info {
  margin-bottom: 20rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.store-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #1976d2;
}

/* 4项筛选一行 */
.filter-row-4 {
  display: flex;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.filter-item-4 {
  flex: 1;
  min-width: 0;
}

.filter-label {
  font-size: 22rpx;
  color: #666;
  margin-bottom: 8rpx;
  display: block;
}

.picker-box {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 64rpx;
  background: #f5f7fa;
  border-radius: 8rpx;
  padding: 0 12rpx;
  font-size: 26rpx;
  color: #333;
}

.picker-text {
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.picker-arrow {
  font-size: 20rpx;
  color: #999;
  flex-shrink: 0;
  margin-left: 4rpx;
}

/* 手机号姓名一行 */
.filter-row-2 {
  display: flex;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.filter-item-half {
  flex: 1;
}

.filter-input {
  height: 64rpx;
  background: #f5f7fa;
  border-radius: 8rpx;
  padding: 0 16rpx;
  font-size: 26rpx;
  color: #333;
  width: 100%;
  box-sizing: border-box;
}

/* 时间选择器行 */
.filter-row-date {
  display: flex;
  gap: 12rpx;
  align-items: flex-end;
  margin-bottom: 16rpx;
}

.filter-item-date {
  flex: 1;
}

.reset-date-btn {
  height: 64rpx;
  padding: 0 24rpx;
  background: #f5f7fa;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: #666;
  flex-shrink: 0;
}

.reset-date-btn:active {
  background: #e0e0e0;
}

.search-btn {
  width: 100%;
  height: 88rpx;
  background: linear-gradient(135deg, #1976d2 0%, #1565c0 100%);
  color: #fff;
  font-size: 32rpx;
  font-weight: bold;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  margin-top: 8rpx;
}

.search-btn[disabled] {
  background: #ccc;
}

/* 结果区域 */
.result-section {
  padding: 0 24rpx;
}

.loading-state,
.empty-state {
  text-align: center;
  padding: 100rpx 0;
  color: #999;
  font-size: 28rpx;
}

.result-header {
  margin-bottom: 20rpx;
}

.result-count {
  font-size: 26rpx;
  color: #666;
}

/* 表格 - 单行展示 */
.card-table {
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.table-header {
  display: flex;
  background: #1976d2;
  padding: 20rpx 16rpx;
}

.th {
  font-size: 26rpx;
  color: #fff;
  font-weight: 500;
  text-align: center;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.table-row {
  display: flex;
  padding: 24rpx 16rpx;
  align-items: center;
  background: #fff;
  border-bottom: 1rpx solid #f0f0f0;
}

.table-row:last-child {
  border-bottom: none;
}

.table-row:active {
  background: #f5f7fa;
}

.td {
  font-size: 26rpx;
  color: #333;
  text-align: center;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.col-name {
  flex: 2;
  text-align: left;
}

.col-type {
  flex: 1.5;
  text-align: center;
}

.col-phone {
  flex: 2;
}

.col-action {
  flex: 1.2;
  display: flex;
  justify-content: center;
}

.action-btn {
  font-size: 24rpx;
  color: #1976d2;
  padding: 8rpx 16rpx;
  background: #e3f2fd;
  border-radius: 8rpx;
}

/* 分页器 */
.pagination {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 30rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: #fff;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.05);
  z-index: 100;
}

.page-size-selector {
  flex-shrink: 0;
}

.page-size-box {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 16rpx 24rpx;
  background: #f5f7fa;
  border-radius: 8rpx;
  font-size: 26rpx;
  color: #333;
}

.page-nav {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.page-btn {
  padding: 16rpx 32rpx;
  background: #1976d2;
  color: #fff;
  font-size: 26rpx;
  border-radius: 8rpx;
}

.page-btn.disabled {
  background: #ccc;
  color: #999;
}

.page-info {
  font-size: 28rpx;
  color: #333;
  min-width: 100rpx;
  text-align: center;
}

/* 详情弹窗 */
.detail-modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
  padding: 40rpx;
  box-sizing: border-box;
}

.detail-modal {
  width: 100%;
  max-width: 650rpx;
  max-height: 80vh;
  background: #fff;
  border-radius: 24rpx;
  overflow: hidden;
  animation: modalFadeIn 0.3s ease;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
}

@keyframes modalFadeIn {
  from {
    opacity: 0;
    transform: scale(0.9);
  }
  to {
    opacity: 1;
    transform: scale(1);
  }
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 30rpx;
  background: linear-gradient(135deg, #1976d2 0%, #1565c0 100%);
  flex-shrink: 0;
}

.modal-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #fff;
}

.modal-close {
  font-size: 44rpx;
  color: rgba(255, 255, 255, 0.8);
  width: 50rpx;
  height: 50rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.modal-body {
  padding: 20rpx 24rpx;
  flex: 1;
  box-sizing: border-box;
  overflow-y: auto;
  overflow-x: hidden;
}

.detail-row {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
  gap: 16rpx;
}

.detail-row:last-child {
  border-bottom: none;
}

.detail-label {
  font-size: 32rpx;
  color: #666;
  flex-shrink: 0;
  min-width: 140rpx;
}

.detail-value {
  font-size: 32rpx;
  color: #333;
  flex: 1;
  text-align: right;
  word-break: break-all;
  line-height: 1.4;
}

.detail-value.highlight {
  font-size: 30rpx;
  font-weight: bold;
  color: #1976d2;
}

.detail-value.status-0 {
  color: #ff9800;
}

.detail-value.status-1 {
  color: #4caf50;
}

.detail-value.status-2 {
  color: #f44336;
}

.detail-value.status-3 {
  color: #9e9e9e;
}

.detail-value.status-4 {
  color: #795548;
}

/* 自定义选择器弹窗 */
.picker-popup-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0);
  z-index: 2000;
  transition: background 250ms ease;
}

.picker-popup-mask.show {
  background: rgba(0, 0, 0, 0.5);
}

.picker-popup {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: #fff;
  border-radius: 24rpx 24rpx 0 0;
  min-height: 300rpx;
  max-height: 70vh;
  transform: translateY(100%);
  transition: transform 250ms ease;
  z-index: 2001;
}

.picker-popup.show {
  transform: translateY(0);
}

.picker-popup-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.picker-popup-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.picker-popup-close {
  font-size: 48rpx;
  color: #999;
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.picker-popup-body {
  padding: 30rpx;
}

.picker-options {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.picker-option {
  padding: 20rpx 32rpx;
  background: #f5f7fa;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #333;
  border: 2rpx solid transparent;
  transition: background 200ms ease, border-color 200ms ease, color 200ms ease;
}

.picker-option.selected {
  background: #e3f2fd;
  border-color: #1976d2;
  color: #1976d2;
}

.picker-popup-footer {
  display: flex;
  gap: 24rpx;
  padding: 24rpx 30rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid #f0f0f0;
}

.picker-cancel-btn,
.picker-confirm-btn {
  flex: 1;
  height: 88rpx;
  border-radius: 12rpx;
  font-size: 30rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
}

.picker-cancel-btn {
  background: #f5f7fa;
  color: #666;
}

.picker-confirm-btn {
  background: linear-gradient(135deg, #1976d2 0%, #1565c0 100%);
  color: #fff;
}

/* 卡种选择器 */
.card-type-body {
  padding: 20rpx 0;
}

.card-type-scroll {
  white-space: nowrap;
  padding: 0 20rpx;
}

.card-type-option {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  width: 260rpx;
  margin-right: 16rpx;
  padding: 16rpx;
  border-radius: 16rpx;
  border: 3rpx solid transparent;
  box-sizing: border-box;
  background: #fafafa;
  vertical-align: top;
  transition: background 200ms ease, border-color 200ms ease;
}

.card-type-option.selected {
  border-color: #1976d2;
  background: #e3f2fd;
}

.card-type-option:last-child {
  margin-right: 20rpx;
}

.card-type-preview-wrapper {
  width: 225rpx;
  display: flex;
  justify-content: center;
}

.card-type-placeholder {
  width: 225rpx;
  height: 142rpx;
  background: #f0f0f0;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #999;
}

.card-type-name {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #333;
  max-width: 225rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  text-align: center;
}
