/* pages/bind-employee/bind-employee.wxss */

.page-container {
  min-height: 100vh;
  background: linear-gradient(180deg, #f0f4f8 0%, #e8eef3 100%);
  padding: 20rpx;
  padding-bottom: 200rpx;
}

/* 店铺信息卡片 */
.store-card {
  background: linear-gradient(150deg, #3C8CE7 20%, #55ace6 100%);
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 32rpx rgba(60, 140, 231, 0.3);
}

.store-header {
  display: flex;
  align-items: center;
}

.store-icon {
  font-size: 60rpx;
  margin-right: 20rpx;
}

.store-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.store-name {
  font-size: 34rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 8rpx;
}

.store-type {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
}

.store-status {
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
}

.store-status.active {
  background: rgba(82, 196, 26, 0.9);
  color: #fff;
}

.store-status.inactive {
  background: rgba(255, 255, 255, 0.3);
  color: #fff;
}

/* 工作令牌状态 */
.token-section {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
}

.section-title {
  display: flex;
  align-items: center;
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 16rpx;
}

.title-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.token-status {
  display: flex;
  align-items: center;
  padding: 20rpx;
  border-radius: 12rpx;
}

.token-status.success {
  background: linear-gradient(135deg, #f6ffed 0%, #d9f7be 100%);
}

.token-status.warning {
  background: linear-gradient(135deg, #fffbe6 0%, #fff1b8 100%);
}

.status-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.token-status.success .status-icon {
  color: #52c41a;
}

.token-status.warning .status-icon {
  color: #faad14;
}

.status-text {
  font-size: 28rpx;
  color: #333;
}

/* 员工列表区域 */
.employee-section {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.employee-count {
  font-size: 26rpx;
  color: #999;
}

.employee-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.employee-item {
  display: flex;
  align-items: center;
  padding: 24rpx 20rpx;
  background: linear-gradient(135deg, #fafafa 0%, #f5f5f5 100%);
  border-radius: 16rpx;
  transition: all 0.2s ease;
}

.employee-item:active {
  transform: scale(0.98);
  background: linear-gradient(135deg, #f0f0f0 0%, #e8e8e8 100%);
}

.employee-avatar {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  background: linear-gradient(150deg, #3C8CE7 20%, #55ace6 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
  color: #fff;
  font-size: 36rpx;
  font-weight: bold;
  flex-shrink: 0;
}

.employee-avatar.manager {
  background: linear-gradient(135deg, #fa8c16 0%, #faad14 100%);
}

.employee-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.employee-name-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.employee-name {
  font-size: 32rpx;
  color: #333;
  font-weight: 600;
}

.role-badge {
  padding: 0 12rpx;
  border-radius: 6rpx;
  height: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.role-badge-text {
  font-size: 24rpx;
  font-weight: 500;
}

.role-badge.manager {
  background: linear-gradient(135deg, #fff7e6 0%, #ffe7ba 100%);
  color: #d46b08;
}

.role-badge.staff {
  background: linear-gradient(135deg, #e6f7ff 0%, #bae7ff 100%);
  color: #0958d9;
}

.employee-phone {
  font-size: 26rpx;
  color: #666;
}

.employee-entry-time {
  font-size: 24rpx;
  color: #999;
}

.employee-arrow {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 48rpx;
  height: 48rpx;
}

.arrow-icon {
  font-size: 40rpx;
  color: #ccc;
  font-weight: 300;
}

/* 加载状态 */
.loading-state {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 40rpx;
}

.loading-text {
  font-size: 28rpx;
  color: #999;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 40rpx;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 30rpx;
  color: #333;
  margin-bottom: 12rpx;
}

.empty-hint {
  font-size: 26rpx;
  color: #999;
}

/* 加载更多 */
.load-more {
  display: flex;
  justify-content: center;
  padding: 24rpx;
}

.load-more-text {
  font-size: 24rpx;
  color: #ccc;
}

/* 操作区域 */
.action-section {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx 30rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  background: #fff;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.08);
}

.bind-btn {
  width: 100%;
  height: 96rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  background: linear-gradient(150deg, #3C8CE7 20%, #55ace6 100%);
  color: #fff;
  border-radius: 16rpx;
  font-size: 32rpx;
  font-weight: 500;
  border: none;
  box-shadow: 0 8rpx 24rpx rgba(60, 140, 231, 0.3);
}

.bind-btn[disabled] {
  background: #d9d9d9;
  box-shadow: none;
}

.bind-btn:active {
  opacity: 0.9;
}

.btn-icon {
  font-size: 40rpx;
  font-weight: 300;
}

/* ==================== 弹窗通用样式 ==================== */
.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modal-container {
  width: 90%;
  max-height: 85vh;
  background: #fff;
  border-radius: 24rpx;
  overflow: hidden;
  display: flex;
  flex-direction: column;
}

.modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx;
  border-bottom: 1rpx solid #f0f0f0;
  background: linear-gradient(150deg, #3C8CE7 20%, #55ace6 100%);
}

.modal-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #fff;
}

.modal-close {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.2);
}

.modal-close text {
  font-size: 32rpx;
  color: #fff;
}

/* ==================== 员工详情弹窗 ==================== */
.detail-content {
  display: flex;
  flex-direction: column;
  flex: 1;
  overflow: hidden;
}

.detail-scroll-area {
  flex: 1;
  padding: 32rpx;
  overflow-y: auto;
  box-sizing: border-box;
  width: 100%;
}

.detail-avatar-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-bottom: 32rpx;
  border-bottom: 1rpx solid #f0f0f0;
  margin-bottom: 24rpx;
}

.detail-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: linear-gradient(150deg, #3C8CE7 20%, #55ace6 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 48rpx;
  font-weight: bold;
  margin-bottom: 16rpx;
}

.detail-avatar.manager {
  background: linear-gradient(135deg, #fa8c16 0%, #faad14 100%);
}

.detail-basic {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.detail-name {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
}

.detail-role-badge {
  padding: 0 20rpx;
  border-radius: 20rpx;
  height: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.detail-role-badge-text {
  font-size: 26rpx;
  font-weight: 500;
}

.detail-role-badge.manager {
  background: linear-gradient(135deg, #fff7e6 0%, #ffe7ba 100%);
  color: #d46b08;
}

.detail-role-badge.staff {
  background: linear-gradient(135deg, #e6f7ff 0%, #bae7ff 100%);
  color: #0958d9;
}

.detail-info-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  width: 100%;
  box-sizing: border-box;
}

.detail-info-item {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.detail-info-item.editable {
  flex-direction: column;
  gap: 12rpx;
}

.info-label {
  font-size: 28rpx;
  color: #999;
  flex-shrink: 0;
}

.info-value {
  font-size: 28rpx;
  color: #333;
  text-align: right;
  word-break: break-all;
  flex: 1;
  overflow: hidden;
}

.detail-info-item.editable .info-value {
  text-align: left;
}

.info-input {
  width: 100%;
  height: 72rpx;
  padding: 0 20rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #333;
}

.info-textarea {
  width: 100%;
  min-height: 120rpx;
  padding: 16rpx 20rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #333;
  box-sizing: border-box;
}

.detail-actions {
  display: flex;
  gap: 20rpx;
  margin-top: 32rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid #f0f0f0;
}

.detail-actions-fixed {
  display: flex;
  gap: 20rpx;
  padding: 24rpx 32rpx;
  border-top: 1rpx solid #f0f0f0;
  background: #fff;
  flex-shrink: 0;
}

.action-btn {
  flex: 1;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 16rpx;
  font-size: 30rpx;
  font-weight: 500;
  border: none;
}

.edit-btn {
  background: linear-gradient(150deg, #3C8CE7 20%, #55ace6 100%);
  color: #fff;
}

.cancel-btn {
  background: #f5f5f5;
  color: #666;
}

.save-btn {
  background: linear-gradient(135deg, #52c41a 0%, #73d13d 100%);
  color: #fff;
}

/* ==================== 添加员工弹窗 ==================== */
.add-form {
  padding: 32rpx;
  overflow-y: auto;
}

.form-item {
  margin-bottom: 28rpx;
}

.form-item.required .form-label::after {
  content: '*';
  color: #ff4d4f;
  margin-left: 4rpx;
}

.required-star {
  color: #ff4d4f;
  margin-left: 4rpx;
}

.form-label {
  display: block;
  font-size: 32rpx;
  color: #333;
  font-weight: 500;
  margin-bottom: 12rpx;
}

.form-input {
  width: 100%;
  height: 88rpx;
  padding: 0 24rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  font-size: 30rpx;
  color: #333;
  box-sizing: border-box;
}

.form-textarea {
  width: 100%;
  min-height: 160rpx;
  padding: 20rpx 24rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  font-size: 30rpx;
  color: #333;
  box-sizing: border-box;
}

/* 角色单选器 */
.role-radio-group {
  display: flex;
  gap: 40rpx;
}

.role-radio-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
}

.radio-circle {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  border: 3rpx solid #ddd;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
  transition: all 0.2s ease;
}

.radio-circle.checked {
  background: linear-gradient(150deg, #3C8CE7 20%, #55ace6 100%);
  border-color: #3C8CE7;
}

.radio-circle text {
  font-size: 28rpx;
  color: #fff;
  font-weight: 600;
}

.radio-label {
  font-size: 32rpx;
  color: #333;
}

.submit-btn {
  width: 100%;
  height: 96rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(150deg, #3C8CE7 20%, #55ace6 100%);
  color: #fff;
  border-radius: 16rpx;
  font-size: 32rpx;
  font-weight: 500;
  border: none;
  margin-top: 40rpx;
  box-shadow: 0 8rpx 24rpx rgba(60, 140, 231, 0.3);
}

.submit-btn:active {
  opacity: 0.9;
}

/* ==================== 权限按钮样式 ==================== */
.permission-btn {
  background: linear-gradient(150deg, #fa8c16 20%, #faad14 100%);
  color: #fff;
}

/* ==================== 步骤表单样式 ==================== */
.add-modal {
  height: 75vh;
  display: flex;
  flex-direction: column;
}

.add-modal .modal-header {
  flex-shrink: 0;
}

/* 头部：步骤指示器 */
.step-header {
  flex-shrink: 0;
  padding: 24rpx 20rpx;
  background: #fff;
  border-bottom: 1rpx solid #f0f0f0;
}

.step-indicators {
  display: flex;
  align-items: center;
  justify-content: center;
}

.step-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.step-num {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: #e8e8e8;
  color: #999;
  font-size: 24rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
}

.step-item.active .step-num {
  background: linear-gradient(150deg, #3C8CE7 20%, #55ace6 100%);
  color: #fff;
}

.step-item.done .step-num {
  background: #52c41a;
  color: #fff;
}

.step-label {
  font-size: 28rpx;
  color: #999;
}

.permission-hint {
  font-size: 26rpx;
  color: #999;
  font-weight: normal;
}

.step-item.active .step-label {
  color: #3C8CE7;
  font-weight: 500;
}

.step-item.done .step-label {
  color: #52c41a;
}

.step-line {
  width: 60rpx;
  height: 4rpx;
  background: #e8e8e8;
  margin: 0 16rpx;
  margin-bottom: 28rpx;
}

.step-line.active {
  background: #52c41a;
}

/* 中间：表单内容区 */
.step-body {
  flex: 1;
  overflow: hidden;
}

.step-content {
  padding: 32rpx;
  box-sizing: border-box;
}

/* 底部：操作按钮 */
.step-footer {
  flex-shrink: 0;
  padding: 24rpx 32rpx;
  background: #fff;
  border-top: 1rpx solid #f0f0f0;
}

.step-footer .step-actions {
  display: flex;
  gap: 24rpx;
}

.step-footer .action-btn {
  flex: 1;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 12rpx;
  font-size: 30rpx;
  font-weight: 500;
  border: none;
}

.step-footer .primary-btn {
  background: linear-gradient(150deg, #3C8CE7 20%, #55ace6 100%);
  color: #fff;
}

.step-footer .secondary-btn {
  background: #f5f5f5;
  color: #666;
}

.step-footer .submit-btn {
  background: linear-gradient(150deg, #3C8CE7 20%, #55ace6 100%);
  color: #fff;
}

/* 信息预览样式 */
.confirm-preview {
  background: #f8f9fa;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-top: 24rpx;
}

.preview-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 16rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #e8e8e8;
}

.preview-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12rpx 0;
}

.preview-label {
  font-size: 30rpx;
  color: #999;
}

.preview-value {
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
  max-width: 400rpx;
  text-align: right;
}

.next-step-btn {
  width: 100%;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(150deg, #3C8CE7 20%, #55ace6 100%);
  color: #fff;
  border-radius: 12rpx;
  font-size: 30rpx;
  font-weight: 500;
  border: none;
  margin-top: 32rpx;
}

.prev-step-btn {
  flex: 1;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #f5f5f5;
  color: #666;
  border-radius: 12rpx;
  font-size: 30rpx;
  font-weight: 500;
  border: none;
}

.step-actions {
  display: flex;
  gap: 20rpx;
  margin-top: 32rpx;
}

.step-actions .submit-btn {
  flex: 1;
  margin-top: 0;
}

/* ==================== 权限表单样式 ==================== */
.permission-form {
  padding: 32rpx;
}

.permission-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 24rpx;
  text-align: center;
}

.permission-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.permission-item {
  display: flex;
  align-items: center;
  padding: 24rpx;
  background: #f8f9fa;
  border-radius: 12rpx;
  transition: all 0.2s ease;
}

.permission-item:active {
  background: #f0f0f0;
}

.checkbox {
  width: 44rpx;
  height: 44rpx;
  border: 3rpx solid #d9d9d9;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  transition: all 0.2s ease;
}

.checkbox.checked {
  background: linear-gradient(150deg, #3C8CE7 20%, #55ace6 100%);
  border-color: #3C8CE7;
}

.checkbox.checked text {
  color: #fff;
  font-size: 28rpx;
  font-weight: bold;
}

.permission-label {
  font-size: 28rpx;
  color: #333;
  flex: 1;
}

.permission-hint {
  font-size: 24rpx;
  color: #999;
  text-align: center;
  margin-top: 24rpx;
}

/* 权限编辑弹窗 */
.permission-modal {
  max-height: 70vh;
}

.permission-modal .permission-form {
  overflow-y: auto;
}

.permission-modal .submit-btn {
  margin-top: 32rpx;
}
