/* pages/profile/profile.wxss */
.container {
    min-height: 100vh;
    background: linear-gradient(135deg, #fafbfc 0%, #f0f2f5 100%);
    padding: 30rpx 0;
}

/* 通用卡片样式 */
.card {
    width: 94%;
    margin: 0 auto 30rpx auto;
    background-color: white;
    border-radius: 24rpx;
    box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.18);
    overflow: hidden;
}

/* 1. 用户基本信息卡片 */
.user-info-card {
    padding: 40rpx 30rpx;
    display: flex;
    align-items: center;
    gap: 30rpx;
    width: 94%;
    margin: 20rpx auto;
    box-sizing: border-box;
}

.user-avatar {
    width: 120rpx;
    height: 120rpx;
    border-radius: 60rpx;
    overflow: hidden;
    border: 4rpx solid #e3f2fd;
}

.avatar-img {
    width: 100%;
    height: 100%;
}

.user-details {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 12rpx;
}

.user-name {
    font-size: 36rpx;
    font-weight: bold;
    color: #333;
}

.user-status {
    font-size: 28rpx;
    color: #666;
}

.arrow-icon {
    font-size: 32rpx;
    color: #ccc;
    font-weight: bold;
}

/* 2. 商家升级卡片 */
.merchant-upgrade-card {
    width: 94%;
    margin: 30rpx auto;
    box-sizing: border-box;
}

.upgrade-header {
    padding: 30rpx;
    display: flex;
    justify-content: space-between;
    align-items: center;
    background: linear-gradient(135deg, #e3f2fd 0%, #f3e5f5 100%);
}

.upgrade-text {
    flex: 1;
}

.upgrade-title {
    font-size: 32rpx;
    font-weight: bold;
    color: #1976d2;
}

.upgrade-button {
    flex-shrink: 0;
}

.upgrade-btn {
    background: linear-gradient(135deg, #1976d2 0%, #42a5f5 100%);
    color: white;
    border: none;
    border-radius: 20rpx;
    padding: 16rpx 32rpx;
    font-size: 28rpx;
    font-weight: bold;
    box-shadow: 0 4rpx 12rpx rgba(25, 118, 210, 0.3);
}

.upgrade-btn::after {
    border: none;
}

.upgrade-btn:active {
    transform: translateY(2rpx);
    box-shadow: 0 2rpx 8rpx rgba(25, 118, 210, 0.3);
}

.divider {
    height: 2rpx;
    background-color: #f0f0f0;
    margin: 0 30rpx;
}

.privileges-grid {
    padding: 30rpx;
    display: flex;
    justify-content: space-between;
    gap: 20rpx;
}

.privilege-item {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16rpx;
}

.privilege-icon {
    width: 80rpx;
    height: 80rpx;
    background-color: pink;
}

.privilege-text {
    font-size: 24rpx;
    color: #666;
    text-align: center;
}

/* 3. 推荐功能卡片 */
.recommend-card {
    width: 94%;
    margin: 0 auto;
    padding: 30rpx;
    box-sizing: border-box;
}

.recommend-header {
    margin-bottom: 30rpx;
}

.recommend-title {
    font-size: 32rpx;
    font-weight: bold;
    color: #333;
}

.recommend-grid {
    display: flex;
    justify-content: space-between;
    gap: 30rpx;
}

.recommend-item {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 20rpx;
    padding: 30rpx 20rpx;
    background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);
    border-radius: 16rpx;
    transition: all 0.3s ease;
}

.recommend-item:active {
    transform: scale(0.95);
    background: linear-gradient(135deg, #e9ecef 0%, #dee2e6 100%);
}

.recommend-icon {
    width: 80rpx;
    height: 80rpx;
    background-color: pink;
}

.recommend-text {
    font-size: 26rpx;
    color: #333;
    font-weight: 500;
    text-align: center;
}

/* 开发测试卡片 */
.dev-tools-card {
    margin-top: 20rpx;
    border: 2rpx dashed #ff9800;
}

.dev-icon {
    font-size: 60rpx;
    margin-bottom: 10rpx;
}