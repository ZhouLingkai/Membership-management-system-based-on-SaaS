/* pages/store_management/store_management.wxss */

.page-container {
  min-height: 100vh;
  background: linear-gradient(180deg, #f0f4f8 0%, #e8eef3 100%);
  padding: 20rpx;
  padding-bottom: 180rpx;
  box-sizing: border-box;
}

/* 头部区域 */
.header-section {
  background-image: linear-gradient(150deg, #3C8CE7 20%, #55ace6 100%);
  border-radius: 20rpx;
  padding: 40rpx 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 8rpx 32rpx rgba(102, 126, 234, 0.3);
}

.header-content {
  display: flex;
  flex-direction: column;
}

.header-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 10rpx;
}

.header-subtitle {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
}

/* 店铺列表 */
.store-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

/* 店铺卡片 */
.store-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
}

.store-info {
  margin-bottom: 24rpx;
}

.store-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.store-name {
  font-size: 34rpx;
  font-weight: 600;
  color: #333;
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.store-status {
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  flex-shrink: 0;
  margin-left: 16rpx;
}

.store-status.active {
  background: linear-gradient(135deg, #52c41a 0%, #73d13d 100%);
  color: #fff;
}

.store-status.inactive {
  background: #f5f5f5;
  color: #999;
}

.store-meta {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.store-type {
  font-size: 26rpx;
  color: #667eea;
  background: rgba(102, 126, 234, 0.1);
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
}

.store-time {
  font-size: 24rpx;
  color: #999;
}

/* 操作按钮区域 */
.store-actions {
  display: flex;
  gap: 20rpx;
  border-top: 1rpx solid #f0f0f0;
  padding-top: 24rpx;
}

.action-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  padding: 20rpx 0;
  border-radius: 12rpx;
  transition: all 0.2s ease;
}

.action-btn:active {
  transform: scale(0.98);
}

.bind-btn {
  background: linear-gradient(135deg, #36cfc9 0%, #13c2c2 100%);
  color: #fff;
}

.card-btn {
  background: linear-gradient(135deg, #ff6b6b 0%, #ff8e8e 100%);
  color: #fff;
}

.detail-btn {
  background: linear-gradient(150deg, #3C8CE7 20%, #55ace6 100%);
  color: #fff;
}

.action-icon {
  font-size: 28rpx;
}

.action-text {
  font-size: 28rpx;
  font-weight: 500;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 40rpx;
  background: #fff;
  border-radius: 20rpx;
  margin-top: 40rpx;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 30rpx;
}

.empty-text {
  font-size: 34rpx;
  color: #333;
  font-weight: 500;
  margin-bottom: 16rpx;
}

.empty-hint {
  font-size: 28rpx;
  color: #999;
  text-align: center;
}

/* 悬浮添加按钮 */
.fab-button {
  position: fixed;
  right: 40rpx;
  bottom: 200rpx;
  width: 110rpx;
  height: 110rpx;
  background: linear-gradient(150deg, #3C8CE7 20%, #55ace6 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 32rpx rgba(102, 126, 234, 0.4);
  z-index: 100;
  transition: all 0.2s ease;
}

.fab-button:active {
  transform: scale(0.95);
  box-shadow: 0 4rpx 16rpx rgba(102, 126, 234, 0.4);
}

.fab-icon {
  font-size: 60rpx;
  color: #fff;
  font-weight: 300;
  line-height: 1;
}

/* 开发测试入口 */
.dev-entry {
  position: fixed;
  left: 40rpx;
  bottom: 200rpx;
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 16rpx 24rpx;
  background: rgba(0, 0, 0, 0.7);
  border-radius: 30rpx;
  z-index: 100;
}

.dev-icon {
  font-size: 28rpx;
}

.dev-text {
  font-size: 24rpx;
  color: #fff;
}