/* pages/cards-detail/cards-detail.wxss */

.page-container {
  min-height: 100vh;
  background: linear-gradient(180deg, #1976d2 0%, #1565c0 200rpx, #f0f4f8 200rpx, #e8eef3 100%);
  padding-bottom: env(safe-area-inset-bottom);
}

/* 加载状态 */
.loading-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 60vh;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.3);
  border-top-color: #fff;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

.loading-text {
  margin-top: 20rpx;
  font-size: 28rpx;
  color: #fff;
}

/* 通用卡片样式 */
.card {
  background: #fff;
  border-radius: 24rpx;
  margin: 0 24rpx 24rpx;
  padding: 32rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
}

/* 顶部会员卡展示 */
.card-display-section {
  position: relative;
  display: flex;
  justify-content: center;
  padding: 40rpx 24rpx 60rpx;
}

.card-overlay {
  position: absolute;
  top: 70rpx;
  left: 60rpx;
  right: 60rpx;
  pointer-events: none;
}

.card-name-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.overlay-card-name {
  font-size: 36rpx;
  font-weight: 600;
  color: #fff;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.3);
}

.overlay-status {
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  font-weight: 500;
}

.overlay-status.status-normal {
  background: rgba(76, 175, 80, 0.9);
  color: #fff;
}

.overlay-status.status-frozen {
  background: rgba(255, 152, 0, 0.9);
  color: #fff;
}

.overlay-status.status-other {
  background: rgba(158, 158, 158, 0.9);
  color: #fff;
}

.overlay-store {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.85);
  margin-top: 8rpx;
  text-shadow: 0 1rpx 4rpx rgba(0, 0, 0, 0.2);
}

/* 数值信息卡片 */
.value-card {
  margin-top: -40rpx;
  position: relative;
  z-index: 10;
}

.value-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 32rpx;
}

.value-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx 0;
}

.value-label {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 8rpx;
}

.value-number {
  font-size: 40rpx;
  font-weight: 600;
  color: #1976d2;
}

.value-number.small {
  font-size: 28rpx;
}

.value-unit {
  font-size: 24rpx;
  font-weight: 400;
  margin-left: 4rpx;
}

/* 详情信息卡片 */
.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 24rpx;
  padding-left: 16rpx;
  border-left: 6rpx solid #1976d2;
}

.info-list {
  display: flex;
  flex-direction: column;
}

.info-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.info-item:last-child {
  border-bottom: none;
}

.info-label {
  font-size: 28rpx;
  color: #666;
}

.info-value {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
  max-width: 400rpx;
  text-align: right;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 卡种描述 */
.description-section {
  margin-top: 24rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid #f0f0f0;
}

.description-title {
  font-size: 26rpx;
  color: #999;
  display: block;
  margin-bottom: 12rpx;
}

.description-content {
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
}

/* 操作区域 */
.action-list {
  display: flex;
  flex-direction: column;
}

.action-item {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.action-item:last-child {
  border-bottom: none;
}

.action-item:active {
  background: #f9f9f9;
  margin: 0 -32rpx;
  padding: 24rpx 32rpx;
}

.action-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
}

.freeze-icon {
  background: linear-gradient(135deg, #42a5f5, #1976d2);
}

.unfreeze-icon {
  background: linear-gradient(135deg, #66bb6a, #43a047);
}

.icon-text {
  font-size: 36rpx;
}

.action-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.action-name {
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
}

.action-desc {
  font-size: 24rpx;
  color: #999;
  margin-top: 4rpx;
}

.action-arrow {
  font-size: 40rpx;
  color: #ccc;
  font-weight: 300;
}

/* 底部安全间距 */
.bottom-safe {
  height: 60rpx;
}

/* 弹窗样式 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modal-container {
  width: 600rpx;
  background: #fff;
  border-radius: 24rpx;
  overflow: hidden;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.modal-close {
  font-size: 48rpx;
  color: #999;
  line-height: 1;
}

.modal-body {
  padding: 32rpx;
}

.modal-hint {
  font-size: 26rpx;
  color: #666;
  display: block;
  margin-bottom: 20rpx;
}

.freeze-reason-input {
  width: 100%;
  height: 200rpx;
  background: #f8f9fa;
  border-radius: 16rpx;
  padding: 20rpx;
  font-size: 28rpx;
  color: #333;
  box-sizing: border-box;
}

.char-count {
  display: block;
  text-align: right;
  font-size: 24rpx;
  color: #999;
  margin-top: 12rpx;
}

.modal-footer {
  display: flex;
  padding: 24rpx 32rpx 32rpx;
  gap: 24rpx;
}

.modal-btn {
  flex: 1;
  height: 88rpx;
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
}

.cancel-btn {
  background: #f0f0f0;
  color: #666;
}

.confirm-btn {
  background: linear-gradient(135deg, #42a5f5, #1976d2);
  color: #fff;
}

.confirm-btn[disabled] {
  background: #ccc;
  color: #999;
}

.unfreeze-confirm-btn {
  background: linear-gradient(135deg, #66bb6a, #43a047);
}

.unfreeze-confirm-btn[disabled] {
  background: #ccc;
  color: #999;
}
