/* pages/merchant-workspace/merchant-workspace.wxss */
page {
    background: linear-gradient(135deg, #fafbfc 0%, #f0f2f5 100%);
}

/* 隐藏页面滚动条 */
::-webkit-scrollbar {
    width: 0;
    height: 0;
    display: none;
}
::-webkit-scrollbar-track {
    display: none;
  }
.page-container {
  position: relative;
}

/* 自定义顶部导航栏 */
.custom-navbar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 1000;
  background: linear-gradient(135deg, #ffffff 0%, #f8f9fa 100%);
  /* padding-top 通过 WXML 动态设置 */
}

.navbar-content {
  display: flex;
  align-items: center;
  justify-content: flex-start;
  padding: 0 30rpx;
  /* height 通过 WXML 动态设置 */
  box-sizing: border-box;
  /* 临时调试背景 - 可以删除 */
  /* background: rgba(255, 0, 0, 0.1); */
}

.store-avatar {
  width: 60rpx;
  height: 60rpx;
  border-radius: 12rpx;
  margin-right: 20rpx;
  border: 2rpx solid #e3f2fd;
  flex-shrink: 0;
}

.store-avatar-text {
  width: 75rpx;
  height: 75rpx;
  border-radius: 12rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.store-avatar-text text {
  font-size: 28rpx;
  font-weight: bold;
  line-height: 1;
}

.store-avatar-empty {
  background-color: #E0E0E0;
}

.store-avatar-empty text {
  color: #9E9E9E;
  font-size: 22rpx;
}

/* 下拉箭头 */
.dropdown-arrow {
  font-size: 20rpx;
  color: #999;
  flex-shrink: 0;
}

.store-name {
  flex: 1;
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
  margin-right: 20rpx;
  line-height: 1;
  display: flex;
  align-items: center;
}

.arrow-icon {
  font-size: 28rpx;
  color: #999;
  font-weight: bold;
}

/* 遮罩层 */
.mask-layer {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.1);
  z-index: 1500;
}

/* 店铺选择卡片 */
.store-card {
  position: fixed;
  /* top 通过 WXML 动态设置 */
  left: 30rpx;
  right: 30rpx;
  background: white;
  border-radius: 24rpx;
  box-shadow: 0 12rpx 48rpx rgba(0, 0, 0, 0.2);
  z-index: 2000;
  overflow: hidden;
  animation: slideDown 0.3s ease-out;
}

@keyframes slideDown {
  from {
    opacity: 0;
    transform: translateY(-20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 30rpx;
  background: linear-gradient(135deg, #e3f2fd 0%, #f3e5f5 100%);
  border-bottom: 2rpx solid #f0f0f0;
}

.card-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #1976d2;
}

.close-icon {
  font-size: 48rpx;
  color: #999;
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: rgba(0, 0, 0, 0.05);
}

/* 二维码名片项 */
.qr-card-item {
  display: flex;
  align-items: center;
  padding: 30rpx;
  border-bottom: 2rpx solid #f5f5f5;
  transition: background 0.2s ease;
}

.qr-card-item:active {
  background: rgba(25, 118, 210, 0.05);
}

.qr-icon {
  width: 50rpx;
  height: 50rpx;
  margin-right: 20rpx;
  background: linear-gradient(135deg, #42a5f5 0%, #1976d2 100%);
  border-radius: 50%;
}

.qr-text {
  flex: 1;
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
}

.arrow-right {
  font-size: 24rpx;
  color: #999;
}

/* 店铺列表 */
.store-list {
  min-height: 200rpx;
  max-height: 600rpx;
}

.store-item {
  display: flex;
  align-items: center;
  padding: 25rpx 30rpx;
  border-bottom: 1rpx solid #f5f5f5;
  transition: background 0.2s ease;
}

.store-item:active {
  background: rgba(25, 118, 210, 0.05);
}

.store-item:last-child {
  border-bottom: none;
}

.store-item-avatar {
  width: 60rpx;
  height: 60rpx;
  border-radius: 12rpx;
  margin-right: 20rpx;
  border: 1rpx solid #e0e0e0;
}

.store-item-avatar-text {
  width: 75rpx;
  height: 75rpx;
  border-radius: 12rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.store-item-avatar-text text {
  font-size: 28rpx;
  font-weight: bold;
  line-height: 1;
}

.store-item-name {
  flex: 1;
  font-size: 30rpx;
  font-size: 28rpx;
  color: #333;
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
}

.check-icon {
  width: 40rpx;
  height: 40rpx;
  background: linear-gradient(135deg, #4caf50 0%, #2e7d32 100%);
  border-radius: 50%;
}

/* 店铺列表加载中/空状态 */
.store-list-loading,
.store-list-empty {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx 0;
  color: #999;
  font-size: 28rpx;
}

.container {
  /* padding-top 通过 WXML 动态设置 */
  padding-bottom: 30rpx;
}

.pos-box {
    width: 100%;
    height: 150rpx;
}

/* ==================== Tab切换样式 ==================== */
.tab-switch-container {
    position: fixed;
    left: 0;
    right: 0;
    height: 80rpx;
    display: flex;
    background-color: #f9fafb;
    z-index: 900;
    box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.tab-switch-item {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    position: relative;
    transition: all 0.3s ease;
}

.tab-switch-item .tab-text {
    font-size: 32rpx;
    color: #888888;
    transition: all 0.3s ease;
}

.tab-switch-item.active .tab-text {
    color: #333333;
    font-weight: bold;
}

.tab-switch-item .tab-underline {
    position: absolute;
    bottom: 4rpx;
    width: 90%;
    height: 6rpx;
    border-radius: 3rpx;
    background: #1976d2;
    transform: scaleX(0);
    transition: transform 0.3s ease;
}

.tab-switch-item.active .tab-underline {
    transform: scaleX(1);
}

/* ==================== 预约系统容器 ==================== */
.reservation-container {
    position: relative;
    min-height: 100vh;
    background: #f5f6fa;
}

/* 空状态 */
.empty-state {
    display: flex;
    align-items: center;
    justify-content: center;
    height: 400rpx;
}

.empty-text {
    font-size: 32rpx;
    color: #999;
}

/* ==================== 表格容器 ==================== */
.reservation-table-wrapper {
    position: relative;
    width: 100%;
    height: calc(100vh - 200rpx);
}

/* 左上角日期单元格 */
.corner-cell {
    position: fixed;
    left: 0;
    background: #ffffff;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    z-index: 800;
    border-right: 1rpx solid rgba(25, 118, 210, 0.2);
    border-bottom: 1rpx solid rgba(25, 118, 210, 0.2);
    border-radius: 12rpx;
    box-shadow: 0 2rpx 12rpx rgba(25, 118, 210, 0.1);
}

.corner-date {
    color: #666;
    font-weight: bold;
    line-height: 1.2;
    margin: 0 0 8rpx;
}

.corner-year-row {
    display: flex;
    align-items: center;
    gap: 6rpx;
}

.corner-year {
    color: #666666;
    line-height: 1.2;
}

.corner-icon {
    max-height: 50rpx;
    font-size: 24rpx;
    color: #1976d2;
}

/* ==================== 表头行 ==================== */
.header-row-wrapper {
    position: fixed;
    right: 0;
    z-index: 700;
    background: #fff;
    overflow: hidden;
}

.header-row-container {
    display: flex;
    will-change: transform;
}

.header-row {
    display: flex;
    background: #ffffff;
}

.header-cell {
    flex-shrink: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    border-right: 1rpx solid #e8eef5;
    border-bottom: 1rpx solid rgba(25, 118, 210, 0.15);
    box-sizing: border-box;
    position: relative;
}

.header-index {
    color: #999;
    line-height: 1.2;
}

.header-time-start {
    color: #333;
    font-weight: 500;
    line-height: 1.3;
}

.header-time-end {
    color: #555;
    line-height: 1.2;
}

/* ==================== 表头列 ==================== */
.header-col-wrapper {
    position: fixed;
    left: 0;
    z-index: 700;
    background: #fff;
    overflow: hidden;
    /* 高度通过JS计算：屏幕高度 - 顶部 - tabBar */
    bottom: calc(48px + env(safe-area-inset-bottom));
    transition: bottom 0.3s ease;
}

.header-col-wrapper.with-form {
    bottom: calc(48px + env(safe-area-inset-bottom) + 240rpx);
}

.header-col-container {
    will-change: transform;
}

.header-col {
    display: flex;
    flex-direction: column;
}

.col-cell {
    flex-shrink: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    background: #ffffff;
    border-right: 1rpx solid rgba(25, 118, 210, 0.15);
    border-bottom: 1rpx solid #e8eef5;
    box-sizing: border-box;
    padding: 4rpx;
    position: relative;
}

.col-cell::before {
    content: '';
    position: absolute;
    left: 0;
    top: 20%;
    width: 3rpx;
    height: 60%;
    background: #1976d2;
    border-radius: 2rpx;
}

.col-name-line1,
.col-name-line2 {
    color: #333;
    text-align: center;
    line-height: 1.3;
    word-break: break-all;
}

.col-name-line2 {
    color: #666;
}

/* ==================== 表格主体 ==================== */
.table-body-scroll {
    position: fixed;
    right: 0;
    bottom: calc(48px + env(safe-area-inset-bottom));
    background: #fff;
    transition: bottom 0.3s ease;
}

.table-body-scroll.with-form {
    bottom: calc(48px + env(safe-area-inset-bottom) + 240rpx);
}

.table-body-scroll::-webkit-scrollbar {
    display: none;
}

/* 表格底部占位 */
.table-bottom-placeholder {
    height: 20rpx;
}

.table-body {
    display: flex;
    flex-direction: column;
    /* 右侧margin已包含在tableBodyWidth中 */
}

.table-row {
    display: flex;
}

.table-cell {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    /* 默认居中，但预约块需要从左侧开始 */
    justify-content: flex-start;
    box-sizing: border-box;
    position: relative;
    /* 允许子元素溢出（用于合并单元格显示） */
    overflow: visible;
    /* 使用伪元素实现短线条虚线边框 */
}

/* 右侧边框 - 淡蓝灰实线 */
.table-cell::after {
    content: '';
    position: absolute;
    right: 0;
    top: 0;
    width: 1rpx;
    height: 100%;
    background: #e8eef5;
    z-index: 5;
}

/* 底部边框 - 淡蓝灰实线 */
.table-cell::before {
    content: '';
    position: absolute;
    left: 0;
    bottom: 0;
    width: 100%;
    height: 1rpx;
    background: #e8eef5;
}

/* 可预约单元格 - 与cell-block尺寸一致 */
.cell-available {
    position: absolute;
    left: 4rpx;
    top: 4rpx;
    width: calc(100% - 8rpx);
    height: calc(100% - 8rpx);
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 6rpx;
    box-sizing: border-box;
}

.cell-text-available {
    color: #4caf50;
    font-weight: 500;
}

/* 已过期单元格 - 灰色不可点击 */
.cell-expired {
    position: absolute;
    left: 4rpx;
    top: 4rpx;
    width: calc(100% - 8rpx);
    height: calc(100% - 8rpx);
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 6rpx;
    box-sizing: border-box;
    z-index: 10;
    background: rgba(158, 158, 158, 0.15);
}

.cell-text-expired {
    color: #9e9e9e;
    font-weight: 500;
}

/* 已预约/占用/停用单元格块 - 可跨越多个单元格 */
.cell-block {
    /* 使用绝对定位脱离文档流，才能真正覆盖后续单元格 */
    position: absolute;
    left: 4rpx;
    top: 4rpx;
    height: calc(100% - 8rpx);
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 12rpx;
    box-sizing: border-box;
    /* 确保合并单元格块覆盖在后续单元格上方 */
    z-index: 10;
}

.cell-block.type-1 {
    background: linear-gradient(135deg, rgba(33, 150, 243, 0.15) 0%, rgba(33, 150, 243, 0.15) 100%), #fff;
    border: 1rpx solid rgba(33, 150, 243, 0.5);
}

.cell-block.type-2 {
    background: linear-gradient(135deg, rgba(255, 193, 7, 0.2) 0%, rgba(255, 193, 7, 0.2) 100%), #fff;
    border: 1rpx solid rgba(255, 193, 7, 0.6);
}

.cell-block.type-3 {
    background: linear-gradient(135deg, rgba(233, 30, 99, 0.15) 0%, rgba(233, 30, 99, 0.15) 100%), #fff;
    border: 1rpx solid rgba(233, 30, 99, 0.5);
}

.cell-block .cell-text {
    color: #333;
    font-weight: 500;
    text-align: center;
}

/* 选中状态 */
.table-cell.selected {
    background: rgba(76, 175, 80, 0.2);
}

.table-cell.selected .cell-available {
    border: 3rpx solid #4caf50;
    border-radius: 12rpx;
    background: rgba(76, 175, 80, 0.1);
}

/* 相邻提示 - 闪烁动画 */
.table-cell.adjacent-hint .cell-available {
    animation: adjacentBlink 1.5s ease-in-out infinite;
    border-radius: 12rpx;
}

@keyframes adjacentBlink {

    0%,
    100% {
        border: 2rpx solid transparent;
        background: transparent;
    }

    50% {
        border: 2rpx solid rgba(76, 175, 80, 0.6);
        background: rgba(76, 175, 80, 0.08);
    }
}

/* ==================== 底部占位组件 ==================== */
.tabbar-placeholder {
    height: calc(48px + env(safe-area-inset-bottom));
}

.tabbar-placeholder.with-form {
    /* tabBar高度 + 表单高度 + 20rpx */
    height: calc(48px + env(safe-area-inset-bottom) + 240rpx);
}

/* ==================== 底部表单 ==================== */
.bottom-form {
    position: fixed;
    left: 0;
    right: 0;
    /* 底部偏移tabBar高度 */
    bottom: calc(48px + env(safe-area-inset-bottom));
    background: #fff;
    padding: 20rpx 30rpx;
    box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.1);
    z-index: 1000;
    transform: translateY(calc(100% + 20rpx));
    opacity: 0;
    transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1), opacity 0.3s ease;
    /* 左上角和右上角圆角 */
    border-top-left-radius: 24rpx;
    border-top-right-radius: 24rpx;
}

.bottom-form.show {
    transform: translateY(0);
    opacity: 1;
}

.form-info {
    margin-bottom: 20rpx;
}

.form-resource-name {
    font-size: 32rpx;
    font-weight: bold;
    color: #333;
    display: block;
    margin-bottom: 16rpx;
}

.form-slots-scroll {
    width: 100%;
    white-space: nowrap;
}

.form-slots {
    display: inline-flex;
    gap: 16rpx;
}

.slot-tag {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 12rpx 24rpx;
    background: linear-gradient(135deg, #e8f5e9 0%, #c8e6c9 100%);
    border-radius: 8rpx;
    font-size: 26rpx;
    color: #2e7d32;
    font-weight: 500;
}

.form-actions {
    display: flex;
    gap: 20rpx;
}

.form-actions button {
    flex: 1;
    height: 80rpx;
    border-radius: 12rpx;
    font-size: 30rpx;
    font-weight: bold;
    border: none;
    display: flex;
    align-items: center;
    justify-content: center;
}

.btn-occupy {
    background: linear-gradient(135deg, #ffb74d 0%, #f57c00 100%);
    color: #fff;
}

.btn-disable {
    background: linear-gradient(135deg, #f48fb1 0%, #e91e63 100%);
    color: #fff;
}

/* ==================== 弹窗样式 ==================== */
.detail-modal-mask {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: rgba(0, 0, 0, 0.5);
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 2000;
}

.detail-modal {
    width: 600rpx;
    background: #fff;
    border-radius: 24rpx;
    overflow: hidden;
    animation: modalFadeIn 0.3s ease;
}

@keyframes modalFadeIn {
    from {
        opacity: 0;
        transform: scale(0.9);
    }

    to {
        opacity: 1;
        transform: scale(1);
    }
}

.detail-modal .modal-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 30rpx;
    border-bottom: 2rpx solid #f0f0f0;
}

.detail-modal.type-1 .modal-header {
    background: linear-gradient(135deg, #e3f2fd 0%, #bbdefb 100%);
}

.detail-modal.type-2 .modal-header {
    background: linear-gradient(135deg, #fff8e1 0%, #ffecb3 100%);
}

.detail-modal.type-3 .modal-header {
    background: linear-gradient(135deg, #fce4ec 0%, #f8bbd9 100%);
}

.detail-modal .modal-title {
    font-size: 34rpx;
    font-weight: bold;
    color: #333;
}

.detail-modal .modal-close {
    font-size: 48rpx;
    color: #999;
    width: 60rpx;
    height: 60rpx;
    display: flex;
    align-items: center;
    justify-content: center;
}

.detail-modal .modal-body {
    padding: 30rpx;
}

.detail-modal .modal-row {
    display: flex;
    margin-bottom: 20rpx;
}

.detail-modal .modal-row:last-child {
    margin-bottom: 0;
}

.detail-modal .modal-label {
    width: 160rpx;
    font-size: 28rpx;
    color: #666;
    flex-shrink: 0;
}

.detail-modal .modal-value {
    flex: 1;
    font-size: 28rpx;
    color: #333;
    word-break: break-all;
}

/* 资源详情弹窗 */
.resource-modal .modal-header {
    background: linear-gradient(135deg, #e8f5e9 0%, #c8e6c9 100%);
}

/* 日期选择器弹窗 */
.date-picker-modal {
    width: 650rpx;
    max-height: 70vh;
    background: #fff;
    border-radius: 24rpx;
    overflow: hidden;
    animation: modalFadeIn 0.3s ease;
}

.date-picker-modal .modal-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 30rpx;
    background: linear-gradient(135deg, #e3f2fd 0%, #bbdefb 100%);
    border-bottom: 2rpx solid #f0f0f0;
}

.date-picker-modal .modal-title {
    font-size: 34rpx;
    font-weight: bold;
    color: #333;
}

.date-picker-modal .modal-close {
    font-size: 48rpx;
    color: #999;
    width: 60rpx;
    height: 60rpx;
    display: flex;
    align-items: center;
    justify-content: center;
}

.date-picker-body {
    padding: 20rpx;
    max-height: 500rpx;
    overflow-y: auto;
}

.date-item {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 24rpx 30rpx;
    margin-bottom: 12rpx;
    background: #f9f9f9;
    border-radius: 12rpx;
    transition: all 0.2s ease;
}

.date-item:last-child {
    margin-bottom: 0;
}

.date-item:active {
    background: #e3f2fd;
}

.date-item.selected {
    background: linear-gradient(135deg, #1976d2 0%, #1565c0 100%);
}

.date-item.selected .date-text,
.date-item.selected .date-weekday {
    color: #fff;
}

.date-item.disabled {
    background: #f0f0f0;
    opacity: 0.6;
}

.date-item.disabled .date-text,
.date-item.disabled .date-weekday {
    color: #bbb;
}

.date-text {
    font-size: 30rpx;
    color: #333;
    font-weight: 500;
}

.date-weekday {
    font-size: 26rpx;
    color: #666;
}

/* ==================== 工作中心 - 新版工具箱样式 ==================== */

/* 顶部筛选栏 */
.filter-bar {
    box-sizing: border-box;
    width: 96%;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0 16rpx;
    /* background: #fff; */
    margin: 0rpx auto 12rpx;
    border-radius: 16rpx;
    /* box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06); */
  }
  
  .filter-tags-scroll {
    flex: 1;
    white-space: nowrap;
    margin-right: 20rpx;
  }
  
  .filter-tags {
    display: inline-flex;
    gap: 10rpx;
  }
  
  .filter-tag {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 10rpx 16rpx;
    font-size: 30rpx;
    color: #666;
    background: #f1f1f5;
    border-radius: 32rpx;
    transition: all 0.3s ease;
    flex-shrink: 0;
  }

.filter-tag.active {
  color: #fff;
  background: linear-gradient(135deg, #1976d2 0%, #1565c0 100%);
  box-shadow: 0 4rpx 12rpx rgba(25, 118, 210, 0.3);
}

/* 视图切换按钮 */
.view-switch {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 6rpx;
  background: #f5f6f8;
  border-radius: 12rpx;
  flex-shrink: 0;
}

.switch-btn {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 10rpx;
  transition: all 0.3s ease;
}

.switch-btn image {
  width: 36rpx;
  height: 36rpx;
  opacity: 0.5;
}

.switch-btn.active {
  background: #fff;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.switch-btn.active image {
  opacity: 1;
}

/* ==================== 一列模式（详细模式） ==================== */
.tools-list {
  padding: 0 24rpx;
}

.tool-item-list {
  display: flex;
  align-items: center;
  padding: 28rpx 24rpx;
  background: #fff;
  border-radius: 20rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
  transition: all 0.3s ease;
}

.tool-item-list:active {
  transform: scale(0.98);
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
}

.tool-icon-wrapper {
  width: 100rpx;
  height: 100rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-right: 24rpx;
}

.tool-icon {
  width: 56rpx;
  height: 56rpx;
}

.tool-info {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.tool-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex-wrap: wrap;
}

.tool-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  line-height: 1.3;
}

.tool-labels {
  display: flex;
  gap: 8rpx;
  flex-wrap: wrap;
}

.tool-label {
  font-size: 22rpx;
  color: #1976d2;
  background: rgba(25, 118, 210, 0.1);
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
  line-height: 1.4;
}

.tool-desc {
  font-size: 28rpx;
  color: #666;
  line-height: 1.5;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
  text-overflow: ellipsis;
}

.tool-arrow {
  flex-shrink: 0;
  margin-left: 16rpx;
}

.arrow-icon {
  font-size: 40rpx;
  color: #ccc;
  font-weight: 300;
}

/* ==================== 四列模式（简单模式） ==================== */
.tools-grid {
  display: flex;
  flex-wrap: wrap;
  padding: 0 24rpx;
  gap: 20rpx;
}

.tool-item-grid {
  width: calc((100% - 60rpx) / 4);
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx 0;
  background: #fff;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
  transition: all 0.3s ease;
}

.tool-item-grid:active {
  transform: scale(0.95);
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
}

.tool-icon-wrapper-grid {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16rpx;
}

.tool-icon-grid {
  width: 48rpx;
  height: 48rpx;
}

.tool-name-grid {
  font-size: 26rpx;
  color: #333;
  text-align: center;
  line-height: 1.3;
  font-weight: 500;
}

/* ==================== 空状态 ==================== */
.empty-tools,
.empty-tools-grid {
  width: 100%;
  padding: 80rpx 0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.empty-tools-grid {
  flex-basis: 100%;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}

/* ==================== 底部占位 ==================== */
.tools-bottom-placeholder {
  height: 120rpx;
}
