/* ==================== 工作中心 - 新版工具箱样式 ==================== */

/* 顶部筛选栏 */
.filter-bar {
  display: flex;
  align-items: center;
  padding: 20rpx 24rpx;
  background: #fff;
  margin: 0 24rpx 20rpx;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.filter-tags-scroll {
  flex: 1;
  white-space: nowrap;
  margin-right: 20rpx;
}

.filter-tags {
  display: inline-flex;
  gap: 16rpx;
}

.filter-tag {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 12rpx 28rpx;
  font-size: 28rpx;
  color: #666;
  background: #f5f6f8;
  border-radius: 32rpx;
  transition: all 0.3s ease;
  flex-shrink: 0;
}

.filter-tag.active {
  color: #fff;
  background: linear-gradient(135deg, #1976d2 0%, #1565c0 100%);
  box-shadow: 0 4rpx 12rpx rgba(25, 118, 210, 0.3);
}

/* 视图切换按钮 */
.view-switch {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 6rpx;
  background: #f5f6f8;
  border-radius: 12rpx;
  flex-shrink: 0;
}

.switch-btn {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 10rpx;
  transition: all 0.3s ease;
}

.switch-btn image {
  width: 36rpx;
  height: 36rpx;
  opacity: 0.5;
}

.switch-btn.active {
  background: #fff;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.switch-btn.active image {
  opacity: 1;
}

/* ==================== 一列模式（详细模式） ==================== */
.tools-list {
  padding: 0 24rpx;
}

.tool-item-list {
  display: flex;
  align-items: center;
  padding: 28rpx 24rpx;
  background: #fff;
  border-radius: 20rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
  transition: all 0.3s ease;
}

.tool-item-list:active {
  transform: scale(0.98);
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
}

.tool-icon-wrapper {
  width: 100rpx;
  height: 100rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-right: 24rpx;
}

.tool-icon {
  width: 56rpx;
  height: 56rpx;
}

.tool-info {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.tool-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex-wrap: wrap;
}

.tool-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  line-height: 1.3;
}

.tool-labels {
  display: flex;
  gap: 8rpx;
  flex-wrap: wrap;
}

.tool-label {
  font-size: 22rpx;
  color: #1976d2;
  background: rgba(25, 118, 210, 0.1);
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
  line-height: 1.4;
}

.tool-desc {
  font-size: 28rpx;
  color: #666;
  line-height: 1.5;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
  text-overflow: ellipsis;
}

.tool-arrow {
  flex-shrink: 0;
  margin-left: 16rpx;
}

.arrow-icon {
  font-size: 40rpx;
  color: #ccc;
  font-weight: 300;
}

/* ==================== 四列模式（简单模式） ==================== */
.tools-grid {
  display: flex;
  flex-wrap: wrap;
  padding: 0 24rpx;
  gap: 20rpx;
}

.tool-item-grid {
  width: calc((100% - 60rpx) / 4);
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx 0;
  background: #fff;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
  transition: all 0.3s ease;
}

.tool-item-grid:active {
  transform: scale(0.95);
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
}

.tool-icon-wrapper-grid {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16rpx;
}

.tool-icon-grid {
  width: 48rpx;
  height: 48rpx;
}

.tool-name-grid {
  font-size: 26rpx;
  color: #333;
  text-align: center;
  line-height: 1.3;
  font-weight: 500;
}

/* ==================== 空状态 ==================== */
.empty-tools,
.empty-tools-grid {
  width: 100%;
  padding: 80rpx 0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.empty-tools-grid {
  flex-basis: 100%;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}

/* ==================== 底部占位 ==================== */
.tools-bottom-placeholder {
  height: 120rpx;
}
