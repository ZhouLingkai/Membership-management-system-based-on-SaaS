/* pages/trans-card-records/trans-card-records.wxss */
.page-container {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding: 20rpx;
}

.card {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

/* 会员卡信息 */
.card-info-section {
  margin-bottom: 20rpx;
}

.info-row {
  display: flex;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.info-row:last-child {
  margin-bottom: 0;
}

.info-item {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.info-item.full-width {
  flex: none;
  width: 100%;
}

.info-label {
  font-size: 28rpx;
  color: #999;
  margin-bottom: 8rpx;
  line-height: 1.5;
  height: auto;
}

.info-value {
  font-size: 32rpx;
  color: #333;
  font-weight: 500;
  line-height: 1.5;
  height: auto;
}

.info-value.highlight {
  color: #1976d2;
  font-weight: 600;
}

.info-value.status-0 {
  color: #999;
}

.info-value.status-1 {
  color: #4caf50;
}

.info-value.status-2 {
  color: #ff9800;
}

.info-value.status-3 {
  color: #f44336;
}

.info-value.status-4 {
  color: #666;
}

/* 日期筛选 */
.filter-section {
  margin-bottom: 20rpx;
}

.filter-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 20rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.reset-all-btn {
  font-size: 28rpx;
  color: #1976d2;
  padding: 8rpx 16rpx;
  background-color: #e3f2fd;
  border-radius: 8rpx;
}

.date-filter-row {
  display: flex;
  justify-content: space-between;
  gap: 20rpx;
  margin-bottom: 20rpx;
}

.date-item {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.date-label {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 12rpx;
}

.date-picker {
  background-color: #f5f5f5;
  border-radius: 8rpx;
  padding: 16rpx;
  border: 1rpx solid #e0e0e0;
}

.date-text {
  font-size: 30rpx;
  color: #333;
}

.filter-btn {
  width: 100%;
  height: 80rpx;
  background: linear-gradient(135deg, #1976d2 0%, #1565c0 100%);
  color: #fff;
  border-radius: 12rpx;
  font-size: 32rpx;
  font-weight: 600;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 记录列表 */
.records-section {
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 20rpx;
  padding-left: 8rpx;
}

.empty-list {
  text-align: center;
  padding: 80rpx 0;
  color: #999;
  font-size: 32rpx;
}

.record-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.record-item {
  padding: 24rpx;
}

.record-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.record-type {
  font-size: 30rpx;
  font-weight: 600;
  padding: 8rpx 20rpx;
  border-radius: 8rpx;
  display: inline-block;
  line-height: 1.4;
  height: auto;
}

.record-type.type-1 {
  background-color: #e3f2fd;
  color: #1976d2;
}

.record-type.type-2 {
  background-color: #fff3e0;
  color: #f57c00;
}

.record-type.type-3 {
  background-color: #ffebee;
  color: #d32f2f;
}

.record-type.type-4,
.record-type.type-5 {
  background-color: #f3e5f5;
  color: #7b1fa2;
}

.record-type.type-add {
  background-color: #e8f5e9;
  color: #388e3c;
}

.record-type.type-reduce {
  background-color: #ffebee;
  color: #d32f2f;
}

.record-time {
  font-size: 28rpx;
  color: #999;
  line-height: 1.4;
  height: auto;
}

.record-body {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.record-row {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
}

.record-label {
  font-size: 30rpx;
  color: #666;
  flex-shrink: 0;
  width: 160rpx;
  line-height: 1.5;
  height: auto;
}

.record-value {
  font-size: 30rpx;
  color: #333;
  flex: 1;
  text-align: right;
  word-break: break-all;
  line-height: 1.5;
  height: auto;
}

.record-value.amount {
  font-size: 36rpx;
  font-weight: 600;
  color: #1976d2;
  line-height: 1.5;
  height: auto;
}

.record-value.positive {
  color: #4caf50;
}

.record-value.negative {
  color: #f44336;
}

.record-value.remark {
  text-align: right;
  color: #666;
}

/* 加载状态 */
.loading-more,
.no-more {
  text-align: center;
  padding: 40rpx 0;
  color: #999;
  font-size: 30rpx;
}
