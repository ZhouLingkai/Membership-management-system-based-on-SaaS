/* pages/login/index.wxss */

.login-container {
    min-height: 100vh;
    /* 上半蓝色渐变，下半白色 */
    background: linear-gradient(to bottom, #3a7bd5 0%, #00d2ff 80%);
    padding: 60rpx 30rpx;
    box-sizing: border-box;
    position: relative;
    overflow: hidden;
  }
  

/* 顶部宣传区域 */

.header-text {
  display: flex;
  flex-direction: column;
  align-items: center;
}
.header-section {
    margin-top: 40rpx;
    margin-bottom: 60rpx;
    text-align: center;
    color: #ffffff;
    position: relative;
    z-index: 1;
  }
  
  .header-text .title {
    font-size: 65rpx;
    font-weight: 700;
    background: linear-gradient(135deg, #ffffff 10%, #d6ecff 100%);
    margin-bottom: 10rpx;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }
  
  .header-text .subtitle {
    font-size: 30rpx;
    opacity: 0.9;
  }
/* 卡片容器 */
.card-container {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 20rpx 30rpx 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
}

