/* pages/merchant-info/merchant-info.wxss */
.page-container {
  min-height: 100vh;
  background: #f5f5f5;
  padding: 20rpx;
}

/* 信息列表 */
.info-list {
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  margin-bottom: 20rpx;
}

.info-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 36rpx 24rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.info-item:last-child {
  border-bottom: none;
}

.info-item.editable {
  cursor: pointer;
}

.info-label {
  font-size: 34rpx;
  color: #555;
  flex-shrink: 0;
}

.info-value {
  font-size: 34rpx;
  color: #333;
}

.info-value-row {
  display: flex;
  align-items: center;
}

.arrow {
  margin-left: 12rpx;
  color: #999;
  font-size: 24rpx;
}

/* 状态标签 */
.status-success {
  color: #52c41a;
}

.status-warning {
  color: #faad14;
}

.status-info {
  color: #1890ff;
}

.status-danger {
  color: #ff4d4f;
}

/* 二级密码管理 */
.password-section {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx 24rpx;
  margin-bottom: 20rpx;
}

.password-row {
  padding: 24rpx 24rpx;
}

.password-btns {
  display: flex;
  gap: 16rpx;
}

.inline-btn {
  padding: 12rpx 28rpx;
  border-radius: 8rpx;
  font-size: 28rpx;
  line-height: 1.2;
  text-align: center;
}

.inline-btn.primary {
  background: #1890ff;
  color: #fff;
}

.inline-btn.primary:active {
  background: #096dd9;
}

.inline-btn.secondary {
  background: #fff;
  color: #1890ff;
  border: 2rpx solid #1890ff;
}

.inline-btn.secondary:active {
  background: #e6f7ff;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.btn-group {
  display: flex;
  gap: 20rpx;
}

.btn {
  flex: 1;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 12rpx;
  font-size: 30rpx;
  border: none;
}

.btn-primary {
  background: #1890ff;
  color: #fff;
}

.btn-secondary {
  background: #fff;
  color: #1890ff;
  border: 2rpx solid #1890ff;
}

.btn-danger {
  background: linear-gradient(135deg, #ff6b6b 0%, #ee5a5a 50%, #dc4747 100%);
  color: #fff;
}

/* 退出登录 */
.logout-section {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx 24rpx;
}

.logout-section .btn {
  width: 100%;
}

/* 遮罩层 */
.mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

/* 弹窗卡片 */
.modal-card {
  width: 600rpx;
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  max-height: 80vh;
  display: flex;
  flex-direction: column;
}

.modal-title {
  font-size: 32rpx;
  font-weight: bold;
  padding: 30rpx 24rpx;
  border-bottom: 1rpx solid #f0f0f0;
  text-align: center;
}

.modal-content {
  padding: 30rpx 24rpx;
  flex: 1;
  overflow-y: auto;
}

.modal-input {
  width: 100%;
  height: 80rpx;
  padding: 0 20rpx;
  border: 2rpx solid #d9d9d9;
  border-radius: 8rpx;
  font-size: 28rpx;
  margin-bottom: 20rpx;
}

.input-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.flex-1 {
  flex: 1;
  margin-bottom: 0;
}

.code-btn {
  height: 80rpx;
  padding: 0 24rpx;
  background: #1890ff;
  color: #fff;
  border-radius: 8rpx;
  font-size: 28rpx;
  border: none;
}

.modal-footer {
  display: flex;
  border-top: 1rpx solid #f0f0f0;
}

.modal-btn {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  font-size: 32rpx;
  border: none;
  border-radius: 0;
  background: #fff;
}

.modal-btn.cancel {
  color: #666;
  border-right: 1rpx solid #f0f0f0;
}

.modal-btn.confirm {
  color: #1890ff;
  font-weight: bold;
}

/* 图片查看器 */
.image-viewer {
  position: relative;
  width: 96%;
  max-width: 700rpx;
}

.view-image {
  width: 100%;
  border-radius: 16rpx;
}

.close-icon {
  position: absolute;
  top: -80rpx;
  right: 0;
  width: 60rpx;
  height: 60rpx;
  line-height: 60rpx;
  text-align: center;
  font-size: 60rpx;
  color: #fff;
  cursor: pointer;
}