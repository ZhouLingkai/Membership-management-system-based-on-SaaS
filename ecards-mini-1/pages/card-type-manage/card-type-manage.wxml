<!--pages/card-type-manage/card-type-manage.wxml-->
<view class="page-container">
  <!-- 店铺信息卡片 -->
  <view class="store-card">
    <view class="store-header">
      <text class="store-icon">🏪</text>
      <view class="store-info">
        <text class="store-name">{{storeName || '未知店铺'}}</text>
      </view>
    </view>
  </view>

  <!-- 工作令牌状态 -->
  <view class="token-section">
    <view class="section-title">
      <text class="title-icon">🔑</text>
      <text>工作令牌状态</text>
    </view>
    <view class="token-status {{hasWorkToken ? 'success' : 'warning'}}">
      <text class="status-icon">{{hasWorkToken ? '✓' : '○'}}</text>
      <text class="status-text">{{hasWorkToken ? '已获取工作令牌' : '正在获取工作令牌...'}}</text>
    </view>
  </view>

  <!-- 卡种列表 -->
  <view class="card-type-section">
    <view class="section-header">
      <view class="section-title">
        <text class="title-icon">💳</text>
        <text>会员卡种</text>
      </view>
      <view class="card-type-count">共 {{total}} 种</view>
    </view>

    <!-- 卡种列表 -->
    <view class="card-type-list" wx:if="{{cardTypeList.length > 0}}">
      <view 
        class="card-type-item" 
        wx:for="{{cardTypeList}}" 
        wx:key="cardTypeId"
        data-cardtypeid="{{item.cardTypeId}}"
        bindtap="onCardTypeClick"
      >
        <view class="card-type-preview-wrapper">
          <card-display width="{{200}}" cardBgc="{{item.cardBgc}}" cardMask="{{item.cardMask}}" />
        </view>
        <view class="card-type-info">
          <view class="card-type-name-row">
            <text class="card-type-name">{{item.cardTypeName}}</text>
            <view class="type-badge type-{{item.cardTtype}}">{{item.cardTtypeName}}</view>
          </view>
          <view class="card-type-meta">
            <text class="meta-item">充值项目: {{item.presetRechargeCount || 0}}</text>
            <text class="meta-item">消费项目: {{item.presetCostCount || 0}}</text>
          </view>
          <view class="card-type-tags">
            <view class="tag {{item.crossStore === 1 ? 'cross-store' : ''}}">
              {{item.crossStore === 1 ? '跨店通用' : '仅本店'}}
            </view>
            <text class="tag notify">{{notifyEnum[item.autoNotify]}}</text>
          </view>
        </view>
        <view class="card-type-arrow">
          <text class="arrow-icon">›</text>
        </view>
      </view>
    </view>

    <!-- 加载状态 -->
    <view class="loading-state" wx:if="{{loading}}">
      <text class="loading-text">加载中...</text>
    </view>

    <!-- 空状态 -->
    <view class="empty-state" wx:if="{{!loading && cardTypeList.length === 0}}">
      <text class="empty-icon">💳</text>
      <text class="empty-text">暂无卡种</text>
      <text class="empty-hint">点击下方按钮创建卡种</text>
    </view>

    <!-- 加载更多提示 -->
    <view class="load-more" wx:if="{{cardTypeList.length > 0 && !hasMore}}">
      <text class="load-more-text">— 已加载全部 —</text>
    </view>
  </view>

  <!-- 创建卡种按钮 -->
  <view class="action-section">
    <button class="create-btn" bindtap="goCreateCardType" disabled="{{!hasWorkToken}}">
      <text class="btn-icon">+</text>
      <text>创建新卡种</text>
    </button>
  </view>

  <!-- ==================== 卡种详情弹窗 ==================== -->
  <view class="modal-overlay" wx:if="{{showDetailModal}}" bindtap="closeDetailModal">
    <view class="modal-container detail-modal" catchtap="stopPropagation">
      <!-- 弹窗头部 -->
      <view class="modal-header">
        <text class="modal-title">卡种详情</text>
        <view class="modal-close" bindtap="closeDetailModal">
          <text>✕</text>
        </view>
      </view>

      <!-- 卡种信息 -->
      <view class="detail-content" wx:if="{{currentCardType}}">
        <!-- 可滚动的信息区域 -->
        <scroll-view class="detail-scroll-area" scroll-y enhanced show-scrollbar="{{false}}">
          <!-- 卡片预览 -->
          <view class="detail-card-preview-wrapper">
            <card-display width="{{600}}" cardBgc="{{currentCardType.cardBgc}}" cardMask="{{currentCardType.cardMask}}" />
          </view>

          <!-- 基本信息 -->
          <view class="detail-section">
            <view class="detail-section-title">基本信息</view>
            <view class="detail-info-list">
              <view class="detail-info-item">
                <text class="info-label">卡种名称</text>
                <text class="info-value">{{currentCardType.cardTypeName}}</text>
              </view>
              <view class="detail-info-item">
                <text class="info-label">卡种类型</text>
                <text class="info-value">{{cardTypeIcon[currentCardType.cardTtype]}} {{currentCardType.cardTtypeName}}</text>
              </view>
              <view class="detail-info-item">
                <text class="info-label">所属店铺</text>
                <text class="info-value">{{currentCardType.storeName}}</text>
              </view>
              <view class="detail-info-item">
                <text class="info-label">卡种描述</text>
                <text class="info-value">{{currentCardType.description || '暂无描述'}}</text>
              </view>
            </view>
          </view>

          <!-- 设置信息 -->
          <view class="detail-section">
            <view class="detail-section-title">设置信息</view>
            <view class="detail-info-list">
              <view class="detail-info-item">
                <text class="info-label">消息通知</text>
                <picker 
                  wx:if="{{isEditing}}"
                  mode="selector"
                  range="{{notifyOptions}}"
                  range-key="label"
                  value="{{editForm.autoNotify}}"
                  bindchange="onNotifyChange"
                >
                  <view class="picker-value">{{notifyOptions[editForm.autoNotify].label}} ▼</view>
                </picker>
                <text wx:else class="info-value">{{currentCardType.autoNotifyName}}</text>
              </view>
              <view class="detail-info-item">
                <text class="info-label">跨店通用</text>
                <view wx:if="{{isEditing}}" class="switch-wrapper">
                  <switch checked="{{editForm.crossStore === 1}}" bindchange="onCrossStoreChange" color="#3C8CE7"/>
                </view>
                <text wx:else class="info-value">{{currentCardType.crossStoreName}}</text>
              </view>
            </view>
          </view>

          <!-- 预设充值项目 -->
          <view class="detail-section">
            <view class="detail-section-title">预设充值项目</view>
            <view class="preset-list" wx:if="{{presetRechargeList.length > 0}}">
              <view class="preset-item" wx:for="{{presetRechargeList}}" wx:key="index">
                <view class="preset-info">
                  <text class="preset-name">{{item.itemName}}</text>
                  <text class="preset-desc">{{item.itemDesc || ''}}</text>
                </view>
                <text class="preset-amount">¥{{item.amount}}</text>
              </view>
            </view>
            <view class="empty-preset" wx:else>
              <text>暂无预设充值项目</text>
            </view>
          </view>

          <!-- 预设消费项目 -->
          <view class="detail-section">
            <view class="detail-section-title">预设消费项目</view>
            <view class="preset-list" wx:if="{{presetCostList.length > 0}}">
              <view class="preset-item" wx:for="{{presetCostList}}" wx:key="index">
                <view class="preset-info">
                  <text class="preset-name">{{item.itemName}}</text>
                  <text class="preset-desc">{{item.itemDesc || ''}}</text>
                </view>
                <text class="preset-amount">¥{{item.amount}}</text>
              </view>
            </view>
            <view class="empty-preset" wx:else>
              <text>暂无预设消费项目</text>
            </view>
          </view>
        </scroll-view>

        <!-- 固定在底部的操作按钮 -->
        <view class="detail-actions-fixed">
          <button class="action-btn edit-btn" bindtap="goUpdateCardType">编辑信息</button>
        </view>
      </view>
    </view>
  </view>

  <!-- 自定义Toast组件 -->
  <custom-toast id="customToast" />
</view>
