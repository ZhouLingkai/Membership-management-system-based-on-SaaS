/* pages/card-type-manage/card-type-manage.wxss */

.page-container {
  min-height: 100vh;
  background: linear-gradient(180deg, #e8f4fc 0%, #f5f5f5 100%);
  padding: 24rpx;
  padding-bottom: 180rpx;
  box-sizing: border-box;
}

/* ==================== 店铺信息卡片 ==================== */
.store-card {
  background: linear-gradient(150deg, #3C8CE7 20%, #55ace6 100%);
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 32rpx rgba(60, 140, 231, 0.3);
}

.store-header {
  display: flex;
  align-items: center;
}

.store-icon {
  font-size: 48rpx;
  margin-right: 20rpx;
}

.store-info {
  flex: 1;
}

.store-name {
  font-size: 36rpx;
  font-weight: 600;
  color: #fff;
}

/* ==================== 工作令牌状态 ==================== */
.token-section {
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
}

.section-title {
  display: flex;
  align-items: center;
  font-size: 30rpx;
  font-weight: 500;
  color: #333;
}

.title-icon {
  margin-right: 12rpx;
  font-size: 32rpx;
}

.token-status {
  display: flex;
  align-items: center;
  margin-top: 16rpx;
  padding: 16rpx 20rpx;
  border-radius: 12rpx;
}

.token-status.success {
  background: linear-gradient(135deg, #e8f5e9 0%, #c8e6c9 100%);
}

.token-status.warning {
  background: linear-gradient(135deg, #fff3e0 0%, #ffe0b2 100%);
}

.status-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.token-status.success .status-icon {
  color: #4caf50;
}

.token-status.warning .status-icon {
  color: #ff9800;
}

.status-text {
  font-size: 28rpx;
  color: #666;
}

/* ==================== 卡种列表区域 ==================== */
.card-type-section {
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.card-type-count {
  font-size: 26rpx;
  color: #999;
}

/* ==================== 卡种列表项 ==================== */
.card-type-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.card-type-item {
  display: flex;
  align-items: center;
  padding: 20rpx;
  background: #fafafa;
  border-radius: 16rpx;
  transition: all 0.2s ease;
}

.card-type-item:active {
  background: #f0f0f0;
  transform: scale(0.98);
}

/* 卡片预览包装器 */
.card-type-preview-wrapper {
  width: 200rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
  border-radius: 12rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
}

/* 卡片预览（旧样式保留） */
.card-type-preview {
  width: 120rpx;
  height: 80rpx;
  border-radius: 12rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  flex-shrink: 0;
  position: relative;
  overflow: hidden;
}

.card-type-preview.bg-1 {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

.card-type-preview.bg-2 {
  background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
}

.card-type-preview.bg-3 {
  background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%);
}

.card-type-preview.bg-4 {
  background: linear-gradient(135deg, #43e97b 0%, #38f9d7 100%);
}

.card-type-preview.bg-default {
  background: linear-gradient(135deg, #3C8CE7 0%, #55ace6 100%);
}

.card-type-name-preview {
  font-size: 20rpx;
  color: #fff;
  font-weight: 500;
  text-overflow: ellipsis;
  overflow: hidden;
  white-space: nowrap;
  max-width: 100rpx;
}

.card-type-badge {
  font-size: 16rpx;
  color: rgba(255, 255, 255, 0.9);
  background: rgba(0, 0, 0, 0.2);
  padding: 2rpx 8rpx;
  border-radius: 6rpx;
  margin-top: 4rpx;
}

/* 卡种信息 */
.card-type-info {
  flex: 1;
  min-width: 0;
}

.card-type-name-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 8rpx;
}

.card-type-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.type-badge {
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
  font-weight: 500;
  flex-shrink: 0;
}

.type-badge.type-1 {
  background: linear-gradient(135deg, #e3f2fd 0%, #bbdefb 100%);
  color: #1976d2;
}

.type-badge.type-2 {
  background: linear-gradient(135deg, #fce4ec 0%, #f8bbd9 100%);
  color: #c2185b;
}

.type-badge.type-3 {
  background: linear-gradient(135deg, #fff3e0 0%, #ffe0b2 100%);
  color: #f57c00;
}

.type-badge.type-4 {
  background: linear-gradient(135deg, #e8f5e9 0%, #c8e6c9 100%);
  color: #388e3c;
}

.card-type-desc {
  font-size: 28rpx;
  color: #999;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  margin-bottom: 8rpx;
}

.card-type-meta {
  display: flex;
  gap: 20rpx;
  margin: 16rpx 2rpx;
}

.meta-item {
  font-size: 28rpx;
  color: #555;
}

.card-type-tags {
  display: flex;
  gap: 12rpx;
}

.tag {
  font-size: 28rpx;
  padding: 8rpx 14rpx;
  border-radius: 6rpx;
  background: #f0f0f0;
  color: #555;
}

.tag.cross-store {
  background: linear-gradient(135deg, #e8f5e9 0%, #c8e6c9 100%);
  color: #388e3c;
}

.tag.notify {
  background: linear-gradient(135deg, #e3f2fd 0%, #bbdefb 100%);
  color: #1976d2;
}

.card-type-arrow {
  margin-left: 12rpx;
}

.arrow-icon {
  font-size: 40rpx;
  color: #ccc;
}

/* ==================== 加载状态 ==================== */
.loading-state {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 60rpx 0;
}

.loading-text {
  font-size: 28rpx;
  color: #999;
}

/* ==================== 空状态 ==================== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 0;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #666;
  margin-bottom: 12rpx;
}

.empty-hint {
  font-size: 26rpx;
  color: #999;
}

/* ==================== 加载更多 ==================== */
.load-more {
  display: flex;
  justify-content: center;
  padding: 24rpx 0;
}

.load-more-text {
  font-size: 24rpx;
  color: #ccc;
}

/* ==================== 创建按钮 ==================== */
.action-section {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  background: #fff;
  box-shadow: 0 -4rpx 16rpx rgba(0, 0, 0, 0.05);
}

.create-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 96rpx;
  background: linear-gradient(150deg, #3C8CE7 20%, #55ace6 100%);
  border-radius: 48rpx;
  color: #fff;
  font-size: 32rpx;
  font-weight: 500;
  border: none;
  box-shadow: 0 8rpx 24rpx rgba(60, 140, 231, 0.4);
}

.create-btn[disabled] {
  background: #ccc;
  box-shadow: none;
}

.btn-icon {
  font-size: 40rpx;
  margin-right: 12rpx;
}

/* ==================== 弹窗通用样式 ==================== */
.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modal-container {
  width: 90%;
  max-height: 85vh;
  background: #fff;
  border-radius: 24rpx;
  overflow: hidden;
  display: flex;
  flex-direction: column;
}

.modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx;
  border-bottom: 1rpx solid #f0f0f0;
  background: linear-gradient(150deg, #3C8CE7 20%, #55ace6 100%);
}

.modal-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #fff;
}

.modal-close {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.2);
}

.modal-close text {
  font-size: 32rpx;
  color: #fff;
}

/* ==================== 卡种详情弹窗 ==================== */
.detail-content {
  display: flex;
  flex-direction: column;
  flex: 1;
  overflow: hidden;
}

.detail-scroll-area {
  flex: 1;
  padding: 24rpx;
  overflow-y: auto;
  box-sizing: border-box;
  width: 100%;
}

/* 详情弹窗卡片预览包装器 */
.detail-card-preview-wrapper {
  margin-bottom: 24rpx;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.15);
}

/* 卡片预览（旧样式保留） */
.detail-card-preview {
  height: 180rpx;
  border-radius: 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
  position: relative;
}

.detail-card-preview.bg-1 {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

.detail-card-preview.bg-2 {
  background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
}

.detail-card-preview.bg-3 {
  background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%);
}

.detail-card-preview.bg-4 {
  background: linear-gradient(135deg, #43e97b 0%, #38f9d7 100%);
}

.detail-card-preview.bg-default {
  background: linear-gradient(135deg, #3C8CE7 0%, #55ace6 100%);
}

.preview-card-name {
  font-size: 36rpx;
  font-weight: 600;
  color: #fff;
  margin-bottom: 12rpx;
}

.preview-card-type {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.9);
  background: rgba(0, 0, 0, 0.2);
  padding: 6rpx 20rpx;
  border-radius: 20rpx;
}

/* 详情区块 */
.detail-section {
  margin-bottom: 24rpx;
}

.detail-section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 16rpx;
  padding-bottom: 12rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.detail-info-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  width: 100%;
  box-sizing: border-box;
}

.detail-info-item {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  padding: 12rpx 0;
}

.detail-info-item.editable {
  flex-direction: column;
  gap: 12rpx;
}

.info-label {
  font-size: 28rpx;
  color: #999;
  flex-shrink: 0;
}

.info-value {
  font-size: 28rpx;
  color: #333;
  text-align: right;
  word-break: break-all;
  flex: 1;
  overflow: hidden;
}

.detail-info-item.editable .info-value {
  text-align: left;
}

.info-input {
  width: 100%;
  height: 72rpx;
  padding: 0 20rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #333;
  box-sizing: border-box;
}

.info-textarea {
  width: 100%;
  min-height: 120rpx;
  padding: 16rpx 20rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #333;
  box-sizing: border-box;
}

.picker-value {
  font-size: 28rpx;
  color: #3C8CE7;
  padding: 8rpx 16rpx;
  background: #e3f2fd;
  border-radius: 8rpx;
}

.switch-wrapper {
  display: flex;
  align-items: center;
}

/* 预设项目列表 */
.preset-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.preset-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 20rpx;
  background: #fafafa;
  border-radius: 12rpx;
}

.preset-info {
  flex: 1;
}

.preset-name {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.preset-desc {
  font-size: 24rpx;
  color: #999;
  margin-left: 12rpx;
}

.preset-amount {
  font-size: 30rpx;
  color: #3C8CE7;
  font-weight: 600;
}

.empty-preset {
  padding: 24rpx;
  text-align: center;
  color: #999;
  font-size: 26rpx;
  background: #fafafa;
  border-radius: 12rpx;
}

/* 底部操作按钮 */
.detail-actions-fixed {
  display: flex;
  gap: 20rpx;
  padding: 24rpx;
  border-top: 1rpx solid #f0f0f0;
  background: #fff;
  flex-shrink: 0;
}

.action-btn {
  flex: 1;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 16rpx;
  font-size: 30rpx;
  font-weight: 500;
  border: none;
}

.edit-btn {
  background: linear-gradient(150deg, #3C8CE7 20%, #55ace6 100%);
  color: #fff;
}

.cancel-btn {
  background: #f5f5f5;
  color: #666;
}

.save-btn {
  background: linear-gradient(150deg, #3C8CE7 20%, #55ace6 100%);
  color: #fff;
}
