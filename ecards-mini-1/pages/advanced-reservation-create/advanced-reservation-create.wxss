/* pages/advanced-reservation-create/advanced-reservation-create.wxss */
.page-container {
  min-height: 100vh;
  background: linear-gradient(180deg, #e8f4fc 0%, #f5f5f5 100%);
  display: flex;
  flex-direction: column;
}

/* 顶部标题卡片 */
.header-card {
  background: linear-gradient(150deg, #1976d2 20%, #42a5f5 100%);
  padding: 40rpx 30rpx;
  box-shadow: 0 8rpx 32rpx rgba(25, 118, 210, 0.3);
}

.header-info {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.header-title {
  font-size: 40rpx;
  font-weight: 600;
  color: #fff;
}

.header-subtitle {
  font-size: 30rpx;
  color: rgba(255, 255, 255, 0.85);
}

/* 内容区 */
.content {
  flex: 1;
  padding: 24rpx;
}

/* 区块卡片 */
.section-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
}

.section-header {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.step-badge {
  width: 52rpx;
  height: 52rpx;
  background: linear-gradient(150deg, #1976d2 20%, #42a5f5 100%);
  color: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: 600;
}

.section-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #333;
}

/* 表单组 */
.form-group {
  background: #fafafa;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.form-group:last-child {
  margin-bottom: 0;
}

.group-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 16rpx;
}

.group-hint {
  font-size: 28rpx;
  color: #999;
  margin-bottom: 20rpx;
  display: block;
}

/* 表单项 */
.form-item {
  margin-bottom: 24rpx;
}

.form-item:last-child {
  margin-bottom: 0;
}

.form-label {
  font-size: 30rpx;
  color: #666;
  display: block;
  margin-bottom: 12rpx;
}

.form-input {
  width: 100%;
  height: 88rpx;
  background: #fff;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 32rpx;
  color: #333;
  box-sizing: border-box;
  border: 2rpx solid #e0e0e0;
}

.form-hint {
  font-size: 28rpx;
  color: #999;
  margin-top: 10rpx;
  display: block;
}

/* 时间范围选择 */
.time-range {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.time-picker-btn {
  flex: 1;
  height: 88rpx;
  background: #fff;
  border-radius: 12rpx;
  border: 2rpx solid #e0e0e0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: #333;
}

.time-sep {
  font-size: 32rpx;
  color: #999;
}

/* 选择器按钮 */
.picker-btn {
  height: 88rpx;
  background: #fff;
  border-radius: 12rpx;
  border: 2rpx solid #e0e0e0;
  display: flex;
  align-items: center;
  padding: 0 24rpx;
  font-size: 32rpx;
  color: #1976d2;
  font-weight: 500;
}

/* 复选框网格 */
.checkbox-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 24rpx;
}

.checkbox-item {
  display: flex;
  align-items: center;
  gap: 10rpx;
  font-size: 30rpx;
  color: #333;
}

/* 开关项 */
.switch-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.switch-item .form-label {
  margin-bottom: 0;
}

/* 操作按钮 */
.action-btn {
  width: 100%;
  height: 88rpx;
  border-radius: 12rpx;
  font-size: 32rpx;
  font-weight: 500;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 20rpx;
}

.action-btn.primary {
  background: linear-gradient(150deg, #1976d2 20%, #42a5f5 100%);
  color: #fff;
  box-shadow: 0 4rpx 16rpx rgba(25, 118, 210, 0.3);
}

.action-btn.secondary {
  background: linear-gradient(135deg, #e3f2fd 0%, #bbdefb 100%);
  color: #1976d2;
  border: 2rpx solid #1976d2;
}

/* 时间段列表 */
.time-slot-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.time-slot-item {
  display: flex;
  align-items: center;
  gap: 10rpx;
  background: linear-gradient(135deg, #e3f2fd 0%, #bbdefb 100%);
  padding: 14rpx 20rpx;
  border-radius: 12rpx;
}

.slot-text {
  font-size: 30rpx;
  color: #1976d2;
}

.slot-delete {
  font-size: 36rpx;
  color: #f44336;
  font-weight: bold;
  line-height: 1;
}

/* 规则列表 */
.rule-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.rule-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: #fff;
  padding: 20rpx 24rpx;
  border-radius: 12rpx;
  border: 2rpx solid #e0e0e0;
}

.rule-text {
  flex: 1;
  font-size: 30rpx;
  color: #666;
}

.rule-delete {
  font-size: 36rpx;
  color: #f44336;
  font-weight: bold;
  margin-left: 16rpx;
}

/* 提交区域 */
.submit-section {
  margin-top: 20rpx;
  padding-bottom: 40rpx;
}

.submit-btn {
  width: 100%;
  height: 96rpx;
  background: linear-gradient(150deg, #1976d2 20%, #42a5f5 100%);
  color: #fff;
  border-radius: 48rpx;
  font-size: 34rpx;
  font-weight: 600;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(25, 118, 210, 0.4);
}

.submit-btn[disabled] {
  background: #ccc;
  box-shadow: none;
}
