/* pages/merchant-mine/merchant-mine.wxss */
.page-container {
  min-height: 100vh;
  background: linear-gradient(180deg, #fafbfc 0%, #f5f6f8 100%);
  padding: 20rpx 0;
}

/* 通用卡片样式 */
.card {
  width: 94%;
  margin: 20rpx auto;
  background: #ffffff;
  border-radius: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
  padding: 40rpx 30rpx;
  box-sizing: border-box;
}

/* 商户基本信息卡片 */
.merchant-info-card {
  display: flex;
  align-items: center;
}

.merchant-avatar {
  width: 120rpx;
  height: 120rpx;
  margin-right: 30rpx;
}

.avatar-img {
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

.merchant-details {
  flex: 1;
}

.merchant-name {
  font-size: 36rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 12rpx;
}

.merchant-status {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.certification-status {
  font-size: 24rpx;
  padding: 6rpx 12rpx;
  border-radius: 12rpx;
  background: #e8f4ff;
  color: #3197e4;
}

.merchant-level {
  font-size: 24rpx;
  padding: 6rpx 12rpx;
  border-radius: 12rpx;
  background: #fff3e0;
  color: #ff9800;
}

/* VIP升级卡片 - 黑金配色 */
.vip-upgrade-card {
  background: linear-gradient(135deg, #f4dfc4 0%, #f3dbbd 100%);
  position: relative;
  overflow: hidden;
}

.vip-upgrade-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, rgba(42, 34, 32, 0.85) 0%, rgba(53, 48, 45, 0.8) 100%);
  z-index: 1;
}

.vip-upgrade-card .vip-header,
.vip-upgrade-card .divider,
.vip-upgrade-card .vip-privileges-grid {
  position: relative;
  z-index: 2;
}

.vip-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
}

.vip-title {
  font-size: 32rpx;
  font-weight: 600;
  background: linear-gradient(135deg, #f4dfc4 0%, #f3dbbd 100%);
  background-clip: text;
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  color: #f4dfc4;
}

.vip-btn {
  font-size: 26rpx;
  color: #2a2220;
  background: linear-gradient(135deg, #f4dfc4 0%, #f3dbbd 100%);
  border: none;
  border-radius: 20rpx;
  padding: 18rpx 24rpx;
  line-height: 1;
  font-weight: 500;
}

.divider {
  height: 2rpx;
  background: linear-gradient(90deg, #f4dfc4 0%, #f3dbbd 100%);
  margin: 30rpx 0;
}

.vip-privileges-grid {
  display: flex;
  justify-content: space-between;
}

.vip-privilege-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  padding: 20rpx 10rpx;
  background: rgba(48, 43, 37, 0.6);
  border-radius: 16rpx;
  margin: 0 8rpx;
}

.vip-privilege-item:first-child {
  margin-left: 0;
}

.vip-privilege-item:last-child {
  margin-right: 0;
}

.vip-privilege-icon {
  width: 60rpx;
  height: 60rpx;
  margin-bottom: 16rpx;
  background: linear-gradient(135deg, #f4dfc4 0%, #f3dbbd 100%);
  border-radius: 12rpx;
}

.vip-privilege-text {
  font-size: 24rpx;
  color: #f4dfc4;
  line-height: 1.2;
  font-weight: 500;
}

/* 推荐功能卡片 */
.recommend-header {
  margin-bottom: 30rpx;
}

.recommend-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
}

.recommend-grid {
  display: flex;
  justify-content: space-between;
}

.recommend-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  padding: 20rpx 10rpx;
  border-radius: 16rpx;
  transition: background-color 0.2s;
}

.recommend-item:active {
  background: #f8f9fa;
}

.recommend-icon {
  width: 60rpx;
  height: 60rpx;
  margin-bottom: 16rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
}

.recommend-text {
  font-size: 24rpx;
  color: #666666;
  line-height: 1.2;
}

