/* pages/use-member-card/use-member-card.wxss */

.page-container {
  min-height: 100vh;
  background: #f5f7fa;
}

/* 搜索区域 */
.search-section {
  background: linear-gradient(135deg, #1976d2 0%, #1565c0 100%);
  padding: 30rpx;
  padding-top: 20rpx;
}

.store-info {
  margin-bottom: 20rpx;
}

.store-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #fff;
  text-align: center;
  margin: 0 0 10rpx 0;
}

.search-box {
  display: flex;
  gap: 20rpx;
}

.search-input {
  flex: 2;
  height: 80rpx;
  background: #fff;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 36rpx;
  color: #333;
}

.search-btn {
  flex: 1;
  height: 80rpx;
  background: #fff;
  color: #1976d2;
  font-size: 32rpx;
  font-weight: bold;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
}

.search-btn[disabled] {
  color: #999;
}

.error-tip {
  display: block;
  margin-top: 16rpx;
  font-size: 30rpx;
  color: rgb(248, 50, 50);
  font-weight: 600;
}

/* 结果区域 */
.result-section {
  padding: 24rpx 0;
}

.result-header {
  padding: 0 24rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.result-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}

.result-user {
  font-size: 28rpx;
  color: #4caf50;
  background: #e8f5e9;
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
}

.result-user.unregistered {
  color: #ff9800;
  background: #fff8e1;
}

/* 卡片列表区域 */
.card-list-section {
  background: #fff;
  border-radius: 16rpx;
  margin-bottom: 24rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}

.section-count {
  font-size: 26rpx;
  color: #1976d2;
  background: #e3f2fd;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
}

.empty-list {
  padding: 60rpx;
  text-align: center;
  color: #999;
  font-size: 28rpx;
}

/* 表格样式 */
.card-table {
  width: 100%;
}

.table-header {
  display: flex;
  background: #fff;
  padding: 20rpx 16rpx;
  border-bottom: 1rpx solid #e0e0e0;
}

.table-header.header-4col {
  margin-top: 16rpx;
}

.th {
  font-size: 32rpx;
  color: #333;
  font-weight: 700;
  text-align: center;
}

.table-row {
  display: flex;
  padding: 0 16rpx;
  border-bottom: 1rpx solid #f0f0f0;
  align-items: center;
}

.table-row:last-child {
  border-bottom: none;
}

.table-row:active {
  background: #f5f7fa;
}

.td {
  height: 90rpx;
  line-height: 90rpx;
  font-size: 32rpx;
  color: #333;
  text-align: center;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.col-name {
  flex: 2;
}

.col-member {
  flex: 1.5;
}

.col-value {
  flex: 1.5;
}

.col-status {
  flex: 1.2;
}

.col-arrow {
  /* flex: 0.5; */
  min-width: 15rpx;
  color: #888;
  font-size: 40rpx;
  font-weight: bold;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 200rpx 0;
}

.empty-icon {
  width: 200rpx;
  height: 200rpx;
  opacity: 0.3;
  margin-bottom: 30rpx;
}

.empty-text {
  font-size: 30rpx;
  color: #999;
}

/* 详情弹窗 */
.detail-modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.detail-modal {
  width: 94%;
  background: #fff;
  border-radius: 24rpx;
  overflow: hidden;
  animation: modalFadeIn 0.3s ease;
}

@keyframes modalFadeIn {
  from {
    opacity: 0;
    transform: scale(0.9);
  }
  to {
    opacity: 1;
    transform: scale(1);
  }
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 28rpx;
  background: linear-gradient(135deg, #1976d2 0%, #1565c0 100%);
}

.modal-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #fff;
}

.modal-close {
  font-size: 48rpx;
  color: rgba(255, 255, 255, 0.8);
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal-body {
  padding: 30rpx;
}

.detail-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.detail-row:last-child {
  border-bottom: none;
}

.detail-label {
  font-size: 32rpx;
  color: #555;
  font-weight: 600;
}

.detail-value {
  font-size: 34rpx;
  color: #333;
  max-width: 380rpx;
  text-align: right;
}

.detail-value.highlight {
  font-size: 32rpx;
  font-weight: bold;
  color: #1976d2;
}

.detail-value.status-0 {
  color: #ff9800;
}

.detail-value.status-1 {
  color: #4caf50;
}

.detail-value.status-2 {
  color: #f44336;
}

.detail-value.status-3 {
  color: #64b5f6;
}

.detail-value.status-4 {
  color: #9e9e9e;
}

/* 表格中的状态样式 */
.td.status-0 {
  color: #ff9800;
}

.td.status-1 {
  color: #4caf50;
}

.td.status-2 {
  color: #f44336;
}

.td.status-3 {
  color: #64b5f6;
}

.td.status-4 {
  color: #9e9e9e;
}

/* 详情弹窗底部按钮 */
.modal-footer {
  padding: 0 30rpx 30rpx;
  border-top: 1rpx solid #f0f0f0;
  padding-top: 20rpx;
}

.footer-buttons {
  display: flex;
  gap: 16rpx;
}

.action-btn {
  flex: 1;
  height: 80rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
  font-weight: 600;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
}

.trans-btn {
  background: linear-gradient(135deg, #42a5f5 0%, #1976d2 100%);
  color: #fff;
}

.points-btn {
  background: linear-gradient(135deg, #66bb6a 0%, #43a047 100%);
  color: #fff;
}

.freeze-btn {
  background: linear-gradient(135deg, #ef5350 0%, #d32f2f 100%);
  color: #fff;
}

.freeze-btn.unfreeze {
  background: linear-gradient(135deg, #ffa726 0%, #fb8c00 100%);
  color: #fff;
}

.action-btn[disabled] {
  background: #e0e0e0;
  color: #999;
}

/* 冻结/解冻表单弹窗 */
.freeze-modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 2000;
}

.freeze-modal {
  width: 86%;
  background: #fff;
  border-radius: 24rpx;
  overflow: hidden;
  animation: modalFadeIn 0.3s ease;
}

.freeze-modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  background: linear-gradient(135deg, #1976d2 0%, #1565c0 100%);
}

.freeze-modal-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #fff;
}

.freeze-modal-close {
  font-size: 48rpx;
  color: rgba(255, 255, 255, 0.8);
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.freeze-modal-body {
  padding: 30rpx;
}

.freeze-form-item {
  margin-bottom: 30rpx;
}

.freeze-label {
  display: block;
  font-size: 30rpx;
  color: #333;
  font-weight: bold;
  margin-bottom: 16rpx;
}

.freeze-textarea {
  width: 100%;
  min-height: 160rpx;
  background: #f5f7fa;
  border-radius: 12rpx;
  padding: 20rpx;
  font-size: 30rpx;
  color: #333;
  box-sizing: border-box;
}

.freeze-error {
  display: block;
  margin-top: 12rpx;
  font-size: 26rpx;
  color: #f44336;
}

.freeze-actions {
  display: flex;
  gap: 20rpx;
  margin-top: 30rpx;
}

.freeze-cancel-btn,
.freeze-confirm-btn {
  flex: 1;
  height: 88rpx;
  border-radius: 12rpx;
  font-size: 32rpx;
  font-weight: bold;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
}

.freeze-cancel-btn {
  background: #f5f7fa;
  color: #666;
}

.freeze-confirm-btn {
  color: #fff;
}

.freeze-confirm-btn.blue {
  background: linear-gradient(135deg, #1976d2 0%, #1565c0 100%);
}

.freeze-confirm-btn.success {
  background: linear-gradient(135deg, #4caf50 0%, #43a047 100%);
}

.freeze-confirm-btn[disabled] {
  background: #e0e0e0;
  color: #999;
}

/* 详情行可点击样式 */
.detail-row.clickable {
  cursor: pointer;
}

.detail-row.clickable:active {
  background: #f5f7fa;
}

.detail-value-with-icon {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.eye-icon {
  width: 36rpx;
  height: 36rpx;
  opacity: 0.6;
}

/* 卡面展示弹窗 */
.card-image-modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.7);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1500;
}

.card-image-modal {
  animation: modalFadeIn 0.3s ease;
}

/* Tab切换栏 */
.tab-bar {
  display: flex;
  background: #f5f7fa;
  border-bottom: 1rpx solid #e0e0e0;
  overflow-x: auto;
  white-space: nowrap;
}

.tab-item {
  flex: 1;
  min-width: 120rpx;
  padding: 20rpx 16rpx;
  text-align: center;
  font-size: 34rpx;
  color: #666;
  position: relative;
  transition: all 0.3s;
}

.tab-item.active {
  color: #1976d2;
  font-weight: bold;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 60rpx;
  height: 4rpx;
  background: #1976d2;
  border-radius: 2rpx;
}

/* 表单区域 */
/* .form-section {
  padding: 0rpx;
} */

.form-item {
  margin-bottom: 30rpx;
}

.form-label {
  display: block;
  font-size: 32rpx;
  color: #333;
  font-weight: bold;
  margin-bottom: 16rpx;
}

.form-value {
  display: block;
  font-size: 32rpx;
  color: #666;
  padding: 20rpx;
  background: #f5f7fa;
  border-radius: 12rpx;
}

.form-value.highlight {
  color: #1976d2;
  font-weight: bold;
  font-size: 36rpx;
}

.form-input {
  width: 100%;
  height: 80rpx;
  background: #f5f7fa;
  border-radius: 12rpx;
  padding: 0 20rpx;
  font-size: 30rpx;
  color: #333;
  box-sizing: border-box;
}

.required-star {
  color: #f44336;
  margin-right: 4rpx;
}

.form-hint {
  display: block;
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #999;
  line-height: 1.5;
}

.radio-group {
  display: flex;
  gap: 30rpx;
}

.radio-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
  font-size: 28rpx;
  color: #333;
}

.picker-view {
  height: 80rpx;
  line-height: 80rpx;
  background: #f5f7fa;
  border-radius: 12rpx;
  padding: 0 20rpx;
  font-size: 30rpx;
  color: #333;
}

.submit-btn {
  width: 100%;
  height: 88rpx;
  background: linear-gradient(135deg, #1976d2 0%, #1565c0 100%);
  color: #fff;
  font-size: 32rpx;
  font-weight: bold;
  border-radius: 12rpx;
  border: none;
  margin-top: 20rpx;
}

.submit-btn[disabled] {
  background: #e0e0e0;
  color: #999;
}

/* 预设项目按钮 */
.preset-btn-wrapper {
  margin-bottom: 20rpx;
}

.preset-btn {
  width: 100%;
  height: 72rpx;
  background: linear-gradient(135deg, #e3f2fd 0%, #bbdefb 100%);
  color: #1976d2;
  font-size: 28rpx;
  font-weight: bold;
  border-radius: 12rpx;
  border: 2rpx solid #1976d2;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
}

.preset-btn-icon {
  font-size: 32rpx;
}

/* 预设项目选择器 */
.preset-selector-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0);
  z-index: 3000;
  transition: background-color 250ms ease;
}

.preset-selector-mask.show {
  background: rgba(0, 0, 0, 0.5);
}

.preset-selector {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  width: 100%;
  max-height: 70vh;
  background: #fff;
  border-radius: 24rpx 24rpx 0 0;
  transform: translateY(100%);
  transition: transform 250ms cubic-bezier(0.4, 0, 0.2, 1);
  z-index: 3001;
}

.preset-selector.show {
  transform: translateY(0);
}

.preset-selector-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.preset-selector-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.preset-selector-close {
  font-size: 48rpx;
  color: #999;
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.preset-selector-body {
  max-height: calc(70vh - 100rpx);
  padding: 20rpx 0;
}

.preset-selector-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 30rpx;
  border-bottom: 1rpx solid #f5f7fa;
  transition: background 0.2s;
}

.preset-selector-item:active {
  background: #f5f7fa;
}

.preset-item-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.preset-item-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}

.preset-item-desc {
  font-size: 26rpx;
  color: #666;
  line-height: 1.4;
}

.preset-item-amount {
  font-size: 32rpx;
  font-weight: bold;
  color: #1976d2;
  margin-left: 20rpx;
}
