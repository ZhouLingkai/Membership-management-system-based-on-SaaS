/* pages/store-detail/store-detail.wxss */

.page-container {
  min-height: 100vh;
  background: #f5f5f5;
  padding: 20rpx;
  padding-bottom: 40rpx;
}

/* 头部区域 */
.header-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 20rpx;
  background: linear-gradient(150deg, #3C8CE7 20%, #55ace6 100%);
  border-radius: 20rpx;
  margin-bottom: 20rpx;
}

.store-photo-wrapper {
  position: relative;
  width: 180rpx;
  height: 180rpx;
}

.store-photo {
  width: 180rpx;
  height: 180rpx;
  border-radius: 20rpx;
  border: 4rpx solid #fff;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.2);
}

.photo-edit-icon {
  position: absolute;
  right: -10rpx;
  bottom: -10rpx;
  width: 50rpx;
  height: 50rpx;
  background: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.15);
  font-size: 24rpx;
}

.store-name-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-top: 20rpx;
}

.store-name {
  font-size: 38rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 12rpx;
}

.store-status {
  padding: 8rpx 24rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
}

.store-status.active {
  background: rgba(82, 196, 26, 0.9);
  color: #fff;
}

.store-status.inactive {
  background: rgba(255, 255, 255, 0.3);
  color: #fff;
}

/* 信息列表 */
.info-list {
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
}

.info-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx 24rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.info-item:last-child {
  border-bottom: none;
}

.info-item.editable {
  cursor: pointer;
}

.info-item.editable:active {
  background: #fafafa;
}

.info-label {
  font-size: 30rpx;
  color: #666;
  flex-shrink: 0;
  min-width: 160rpx;
}

.info-value {
  font-size: 30rpx;
  color: #333;
  text-align: right;
}

.info-value.address {
  max-width: 400rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.info-value-row {
  display: flex;
  align-items: center;
  flex: 1;
  justify-content: flex-end;
}

.info-image {
  width: 80rpx;
  height: 80rpx;
  border-radius: 8rpx;
  margin-right: 12rpx;
}

.arrow {
  margin-left: 12rpx;
  color: #ccc;
  font-size: 24rpx;
}

/* 遮罩层 */
.mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

/* 弹窗卡片 */
.modal-card {
  width: 600rpx;
  background: #fff;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 20rpx 60rpx rgba(0, 0, 0, 0.15);
}

.modal-title {
  font-size: 34rpx;
  font-weight: 600;
  padding: 36rpx 24rpx;
  border-bottom: 1rpx solid #f0f0f0;
  text-align: center;
  color: #333;
}

.modal-content {
  padding: 40rpx 32rpx;
}

.modal-input {
  width: 100%;
  height: 88rpx;
  padding: 0 20rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 12rpx;
  font-size: 30rpx;
  box-sizing: border-box;
}

.modal-input:focus {
  border-color: #667eea;
}

.picker-view {
  display: flex;
  justify-content: space-between;
  align-items: center;
  height: 88rpx;
  padding: 0 20rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 12rpx;
  font-size: 30rpx;
}

.picker-arrow {
  color: #999;
  font-size: 24rpx;
}

.switch-options {
  display: flex;
  gap: 20rpx;
}

.switch-option {
  flex: 1;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2rpx solid #e0e0e0;
  border-radius: 12rpx;
  font-size: 30rpx;
  color: #666;
  transition: all 0.2s ease;
}

.switch-option.active {
  border-color: #667eea;
  background: linear-gradient(150deg, #3C8CE7 20%, #55ace6 100%);
  color: #fff;
}

.modal-footer {
  display: flex;
  padding: 24rpx 32rpx 32rpx;
  gap: 24rpx;
}

.modal-btn {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  font-size: 30rpx;
  border: none;
  border-radius: 44rpx;
  text-align: center;
}

.modal-btn.cancel {
  color: #666;
  background: #f5f5f5;
}

.modal-btn.confirm {
  color: #fff;
  background: linear-gradient(150deg, #3C8CE7 20%, #55ace6 100%);
  font-weight: 500;
}

/* 操作面板 */
.action-sheet {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  border-radius: 24rpx 24rpx 0 0;
  padding-bottom: env(safe-area-inset-bottom);
}

.action-item {
  height: 110rpx;
  line-height: 110rpx;
  text-align: center;
  font-size: 32rpx;
  color: #333;
  border-bottom: 1rpx solid #f0f0f0;
}

.action-item:active {
  background: #f5f5f5;
}

.action-item.cancel {
  color: #999;
  margin-top: 16rpx;
  border-top: 16rpx solid #f5f5f5;
  border-bottom: none;
}

/* 图片查看器 */
.image-viewer {
  position: relative;
  width: 96%;
  max-width: 700rpx;
}

.view-image {
  width: 100%;
  border-radius: 16rpx;
}

.close-icon {
  position: absolute;
  top: -80rpx;
  right: 0;
  width: 60rpx;
  height: 60rpx;
  line-height: 60rpx;
  text-align: center;
  font-size: 60rpx;
  color: #fff;
}

/* 上传进度 */
.progress-card {
  width: 500rpx;
  background: #fff;
  border-radius: 20rpx;
  padding: 40rpx;
  text-align: center;
}

.progress-title {
  font-size: 32rpx;
  color: #333;
  margin-bottom: 30rpx;
}

.progress-text {
  margin-top: 16rpx;
  font-size: 28rpx;
  color: #666;
}
