  }
  
  .advanced-bg-preview {
    width: 100%;
    height: 120rpx;
    border-radius: 8rpx;
    border: 1rpx solid #ddd;
  }
  
  .advanced-bg-name {
    font-size: 24rpx;
    color: #666;
  }
  
  .advanced-bg-item.selected .advanced-bg-name {
    color: #3C8CE7;
    font-weight: 500;
  }
  
  /* ==================== 自定义背景 ==================== */
  .custom-bg-container {
    display: flex;
    align-items: center;
    gap: 16rpx;
  }
  
  .custom-bg-preview {
    width: 120rpx;
    height: 120rpx;
    border-radius: 8rpx;
