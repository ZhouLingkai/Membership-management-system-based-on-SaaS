  }
  
  /* ==================== 背景选择 ==================== */
  .bg-select-row {
    display: flex;
    gap: 16rpx;
  }
  
  .bg-select-item {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8rpx;
    padding: 12rpx;
    border-radius: 12rpx;
    border: 2rpx solid transparent;
    transition: all 0.2s ease;
  }
  
  .bg-select-item.selected {
    border-color: #3C8CE7;
    background: #e3f2fd;
  }
  
  .bg-preview {
    width: 100%;
    height: 80rpx;
    border-radius: 8rpx;
    box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
  }
  
  .bg-name {
    font-size: 24rpx;
    color: #666;
  }
  
  .bg-select-item.selected .bg-name {
    color: #3C8CE7;
    font-weight: 500;
  }
  
  .bg-custom {
    display: flex;
    align-items: center;
    justify-content: center;
    background: #f5f5f5;
    position: relative;
    overflow: hidden;
  }
  
  .bg-custom image {
    width: 100%;
    height: 100%;
  }
  
  .upload-icon {
    font-size: 48rpx;
    color: #999;
    font-weight: 300;
  }
  
  .custom-bg-row {
    display: flex;
    align-items: center;
    gap: 16rpx;
    margin-top: 16rpx;
  }
  
  .change-bg-btn {
    flex: 1;
    height: 64rpx;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #3C8CE7;
    color: white;
    border-radius: 8rpx;
    font-size: 28rpx;
  }
  
  /* ==================== 渐变色选择 ==================== */
  .gradient-group {
    display: flex;
    flex-wrap: wrap;
    gap: 16rpx;
  }
  
  .gradient-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8rpx;
    cursor: pointer;
  }
  
  .gradient-preview {
    width: 80rpx;
    height: 80rpx;
    border-radius: 8rpx;
    border: 3rpx solid transparent;
    transition: all 0.3s;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }
  
  .gradient-check {
    color: white;
    font-size: 40rpx;
    font-weight: bold;
    text-shadow: 0 0 4rpx rgba(0, 0, 0, 0.5);
  }
  
  .gradient-item.selected .gradient-preview {
    border-color: #3C8CE7;
    box-shadow: 0 0 0 2rpx rgba(60, 140, 231, 0.2);
  }
  
  .gradient-name {
    font-size: 24rpx;
    color: #666;
  }
  
  .gradient-item.selected .gradient-name {
    color: #3C8CE7;
    font-weight: 500;
  }
  
  /* ==================== VIP高级图片选择 ==================== */
  .vip-advanced-group {
    display: flex;
    flex-wrap: wrap;
    gap: 16rpx;
  }
  
  .vip-advanced-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8rpx;
    padding: 12rpx;
    border-radius: 12rpx;
    border: 2rpx solid transparent;
    transition: all 0.2s ease;
    cursor: pointer;
  }
  
  .vip-advanced-item.selected {
    border-color: #3C8CE7;
    background: #e3f2fd;
  }
  
  .vip-preview {
    width: 120rpx;
    height: 68rpx; /* 16:9比例 */
    border-radius: 8rpx;
    background: #f5f5f5;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }
  
  .vip-preview image {
    width: 100%;
    height: 100%;
  }
  
  .vip-name {
    font-size: 24rpx;
    color: #666;
  }
  
  .vip-advanced-item.selected .vip-name {
    color: #3C8CE7;
    font-weight: 500;
  }
  
  /* ==================== 图案位置布局 ==================== */
  .pattern-position-group {
    display: flex;
    flex-direction: column;
    gap: 12rpx;
  }
  
  .position-row {
    display: flex;
    gap: 12rpx;
  }
  
  .position-row .radio-item {
    flex: 1;
  }
  
  /* ==================== 单选组 ==================== */
  .radio-group {
    display: flex;
    gap: 12rpx;
    flex-wrap: wrap;
  }
  
  .radio-item {
    flex: 1;
    min-width: 120rpx;
    height: 64rpx;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #f5f5f5;
    border-radius: 12rpx;
    border: 2rpx solid transparent;
    font-size: 26rpx;
    color: #666;
    transition: all 0.2s ease;
  }
  
  .radio-item.active {
    background: #e3f2fd;
    border-color: #3C8CE7;
    color: #3C8CE7;
    font-weight: 500;
  }
  
  /* ==================== 颜色选择 ==================== */
  .color-group {
    display: flex;
    justify-content: space-between;
    gap: 16rpx;
    flex-wrap: wrap;
  }
  
  .color-item {
    width: 60rpx;
    height: 60rpx;
    border-radius: 50%;
    position: relative;
    transition: all 0.2s ease;
    box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
  }
  
  .color-item.selected::after {
    content: '✓';
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    color: #fff;
    font-size: 32rpx;
    font-weight: bold;
    text-shadow: 0 0 4rpx rgba(0, 0, 0, 0.5);
  }
  
  .color-item.selected {
    transform: scale(1.1);
    box-shadow: 0 4rpx 12rpx rgba(60, 140, 231, 0.4);
  }
  
  /* ==================== 图案选择 ==================== */
  .pattern-group {
    display: flex;
    gap: 20rpx;
  }
  
  .pattern-item {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12rpx;
    padding: 16rpx;
    border-radius: 12rpx;
    border: 2rpx solid transparent;
    transition: all 0.2s ease;
  }
  
  .pattern-item.selected {
    border-color: #3C8CE7;
    background: #e3f2fd;
  }
  
  .pattern-preview {
    width: 100%;
    height: 120rpx;
    border-radius: 8rpx;
    background: #f5f5f5;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }
  
  .pattern-preview image {
    width: 100%;
    height: 100%;
  }
  
  .pattern-preview.no-pattern {
    font-size: 28rpx;
    color: #999;
  }
  
  .pattern-name {
    font-size: 24rpx;
    color: #666;
  }
  
  .pattern-item.selected .pattern-name {
    color: #3C8CE7;
    font-weight: 500;
  }
  
  /* ==================== Canvas蒙版预览 ==================== */
  .mask-canvas-wrapper {
    width: 100%;
    position: relative;
    background: 
      repeating-conic-gradient(#f0f0f0 0% 25%, white 0% 50%) 
      50% / 20px 20px;
    border-radius: 12rpx;
    overflow: hidden;
    box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.1);
  }
  
  .mask-canvas-hidden {
    width: 100%;
    height: 320rpx;
    position: absolute;
    left: -9999rpx; /* 隐藏在屏幕外，仅用于绘制 */
    opacity: 0;
    pointer-events: none;
  }
  
  .mask-preview-image {
    width: 100%;
    height: auto; /* 高度自适应，保持图片原比例 */
    display: block;
  }
  
  .preview-placeholder {
    width: 100%;
    height: 320rpx;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #f5f5f5;
    color: #999;
    font-size: 28rpx;
  }
  
  .canvas-hint {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(255, 255, 255, 0.9);
    color: #999;
    font-size: 28rpx;
    pointer-events: none;
  }
  
  /* ==================== 底部操作按钮 ==================== */
  .bottom-actions {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    display: flex;
    gap: 16rpx;
    padding: 20rpx;
    background: #fff;
    box-shadow: 0 -4rpx 12rpx rgba(0, 0, 0, 0.08);
    z-index: 100;
  }
  
  .action-btn {
    flex: 1;
    height: 80rpx;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 12rpx;
    font-size: 28rpx;
    font-weight: 500;
    transition: all 0.2s ease;
  }
  
  .secondary-btn {
    background: #f5f5f5;
    color: #666;
  }
  
  .secondary-btn:active {
    background: #e0e0e0;
  }
  
  .primary-btn {
    background: linear-gradient(135deg, #3C8CE7 0%, #55ace6 100%);
    color: #fff;
    box-shadow: 0 4rpx 12rpx rgba(60, 140, 231, 0.3);
  }
  
  .primary-btn:active {
    opacity: 0.8;
  }
  
  .success-btn {
    background: linear-gradient(135deg, #4CAF50 0%, #66BB6A 100%);
    color: #fff;
    box-shadow: 0 4rpx 12rpx rgba(76, 175, 80, 0.3);
  }
  
  .success-btn:active {
    opacity: 0.8;
  }
  
  /* ==================== OSS结果 ==================== */
  .oss-result {
    background: #fff;
    border-radius: 16rpx;
    padding: 32rpx;
    margin-bottom: 20rpx;
    box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
  }
  
  .result-title {
    font-size: 32rpx;
    font-weight: 600;
    color: #4CAF50;
    margin-bottom: 20rpx;
  }
  
  .result-item {
    margin-bottom: 16rpx;
    display: flex;
    flex-direction: column;
    gap: 8rpx;
  }
  
  .result-label {
    font-size: 24rpx;
    color: #999;
  }
  
  .result-value {
    font-size: 26rpx;
    color: #333;
    word-break: break-all;
  }
  
  .result-value.small {
    font-size: 22rpx;
    color: #666;
  }
  
  /* ==================== 渐变方向选择 ==================== */
  .gradient-direction-group {
    display: flex;
    gap: 16rpx;
    justify-content: space-between;
