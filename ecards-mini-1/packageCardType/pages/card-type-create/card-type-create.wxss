/* pages/card-type-create/card-type-create.wxss */

.page-container {
  min-height: 100vh;
  background: linear-gradient(180deg, #e8f4fc 0%, #f5f5f5 100%);
  display: flex;
  flex-direction: column;
  position: relative;
}

.form-scroll {
    width: 96%;
    margin: 0 auto;
    padding: 24rpx 0;
    flex: 1;
     padding-bottom: 0;
}

/* ==================== 表单卡片 ==================== */
.form-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx;
  width: 96%;
  margin: 0 auto;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
  box-sizing: border-box;
}

.card-title {
  display: flex;
  align-items: center;
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 24rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.card-icon {
  margin-right: 12rpx;
  font-size: 32rpx;
}

/* ==================== 表单项 ==================== */
.form-item {
  margin-bottom: 24rpx;
}

.form-item:last-child {
  margin-bottom: 0;
}

.form-label {
  display: block;
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
  margin-bottom: 12rpx;
}

.required-star {
  color: #ff4d4f;
  margin-left: 4rpx;
}

.form-input {
  width: 100%;
  height: 88rpx;
  padding: 0 24rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  font-size: 30rpx;
  color: #333;
  box-sizing: border-box;
}

.form-textarea {
  width: 100%;
  min-height: 160rpx;
  padding: 20rpx 24rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  font-size: 30rpx;
  color: #333;
  box-sizing: border-box;
}

/* ==================== 卡种类型选择 ==================== */
.type-radio-group {
  display: flex;
  gap: 16rpx;
  flex-wrap: wrap;
}

/* 余额卡独占一行 */
.type-radio-group-single {
  margin-bottom: 16rpx;
}

/* 其余三个卡种占一行 */
.type-radio-group-triple {
  margin-bottom: 0;
}

.type-radio-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 16rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  border: 2rpx solid transparent;
  transition: all 0.2s ease;
  box-sizing: border-box;
}

/* 余额卡占满宽 */
.type-radio-item-full {
  width: 100%;
}

/* 其余三个卡种均分宽度，考虑gap的影响 */
.type-radio-group-triple .type-radio-item {
  width: calc((100% - 32rpx) / 3);
  flex: none;
}

.type-radio-item.active {
  background: #e3f2fd;
  border-color: #3C8CE7;
}

.type-icon {
  font-size: 40rpx;
  margin-bottom: 8rpx;
}

.type-name {
  font-size: 26rpx;
  color: #666;
}

.type-radio-item.active .type-name {
  color: #3C8CE7;
  font-weight: 500;
}

/* ==================== 卡面背景/蒙版选择 ==================== */
.card-bg-row {
  display: flex;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.card-bg-row:last-child {
  margin-bottom: 0;
}

.card-bg-item {
  width: calc((100% - 32rpx) / 3);
  height: 130rpx; /* 按会员卡比例 1.585:1 */
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 3rpx solid transparent;
  transition: all 0.3s ease;
  position: relative;
  overflow: hidden;
  box-sizing: border-box;
}

.card-bg-item.selected {
  border-color: #3C8CE7;
  box-shadow: 0 6rpx 16rpx rgba(60, 140, 231, 0.4);
  transform: scale(1.02);
}

/* 占位元素，不可见 */
.card-bg-placeholder {
  opacity: 0;
  pointer-events: none;
}

/* ==================== 高端黑金色渐变背景 ==================== */
.bg-luxury {
  background: 
    radial-gradient(circle at 30% 30%, rgba(255, 215, 0, 0.3) 0%, transparent 50%),
    linear-gradient(135deg, #1a1a1a 0%, #2d2d2d 20%, #FFD700 50%, #FFA500 70%, #1a1a1a 100%);
  position: relative;
}

.bg-luxury::before {
  content: '';
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 60%;
  background: 
    radial-gradient(ellipse at 50% 100%, rgba(255, 215, 0, 0.2) 0%, transparent 60%);
  opacity: 0.8;
}

.bg-luxury::after {
  content: '';
  position: absolute;
  inset: 0;
  background: 
    repeating-linear-gradient(90deg, transparent, transparent 40rpx, rgba(255, 215, 0, 0.05) 40rpx, rgba(255, 215, 0, 0.05) 41rpx);
}

/* ==================== 简约清新背景 ==================== */
.bg-simple {
  background: linear-gradient(135deg, #E0F7FA 0%, #B2EBF2 50%, #81D4FA 100%);
  position: relative;
}

.bg-simple::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 40%;
  background: 
    radial-gradient(ellipse at 50% 0%, rgba(255, 255, 255, 0.3) 0%, transparent 60%);
}

.bg-simple::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 30%;
  background: 
    linear-gradient(90deg, transparent 0%, rgba(255, 255, 255, 0.2) 50%, transparent 100%);
}

/* ==================== 科技赛博风背景 ==================== */
.bg-tech {
  background: 
    linear-gradient(45deg, rgba(0, 255, 255, 0.3) 0%, transparent 50%),
    linear-gradient(135deg, #00F5FF 0%, #0EA5E9 30%, #7928CA 70%, #4C1D95 100%);
  position: relative;
}

.bg-tech::before {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 120%;
  height: 120%;
  background: 
    repeating-linear-gradient(0deg, transparent, transparent 10rpx, rgba(0, 255, 255, 0.1) 10rpx, rgba(0, 255, 255, 0.1) 11rpx);
  opacity: 0.5;
}

/* ==================== 复古质感背景 ==================== */
.bg-retro {
  background: 
    linear-gradient(135deg, #D946EF 0%, #C026D3 30%, #B45309 70%, #92400E 100%);
  position: relative;
}

.bg-retro::before {
  content: '';
  position: absolute;
  inset: 0;
  background: 
    radial-gradient(circle at 20% 30%, rgba(251, 191, 36, 0.25) 0%, transparent 40%),
    radial-gradient(circle at 80% 70%, rgba(251, 191, 36, 0.2) 0%, transparent 40%);
}

.bg-retro::after {
  content: '';
  position: absolute;
  inset: 0;
  background-image: 
    repeating-linear-gradient(45deg, transparent, transparent 2rpx, rgba(0, 0, 0, 0.03) 2rpx, rgba(0, 0, 0, 0.03) 4rpx);
}

/* ==================== 梦幻马卡龙背景 ==================== */
.bg-dream {
  background: 
    radial-gradient(circle at 20% 50%, rgba(240, 171, 252, 0.4) 0%, transparent 50%),
    radial-gradient(circle at 80% 50%, rgba(167, 192, 255, 0.4) 0%, transparent 50%),
    linear-gradient(135deg, #F0ABFC 0%, #DDD6FE 25%, #A7C0FF 50%, #FBCFE8 75%, #FFC1E9 100%);
  position: relative;
}

.bg-dream::before {
  content: '';
  position: absolute;
  inset: 0;
  background: 
    radial-gradient(ellipse at 30% 40%, rgba(255, 255, 255, 0.2) 0%, transparent 40%),
    radial-gradient(ellipse at 70% 60%, rgba(255, 255, 255, 0.15) 0%, transparent 40%);
}

/* ==================== 自定义上传 ==================== */
.bg-custom {
  background: #f5f5f5;
  flex-direction: column;
  border: 2rpx dashed #ccc;
  gap: 8rpx;
}

.upload-icon {
  font-size: 40rpx;
  color: #999;
}

.upload-text {
  font-size: 22rpx;
  color: #999;
}

/* ==================== 选中标记 ==================== */
.check-icon {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  font-size: 48rpx;
  color: #fff;
  font-weight: bold;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.5);
  z-index: 10;
}

/* ==================== 蒙版样式 ==================== */
/* 径向渐变蒙版 */
.mask-radial {
  background: radial-gradient(circle at center, rgba(255, 255, 255, 0) 0%, rgba(0, 0, 0, 0.4) 100%);
}

/* 线性渐变蒙版 */
.mask-linear {
  background: linear-gradient(180deg, rgba(0, 0, 0, 0.1) 0%, rgba(0, 0, 0, 0.3) 100%);
}

/* 矩形渐变蒙版 */
.mask-rect {
  background: 
    linear-gradient(90deg, rgba(0, 0, 0, 0.3) 0%, rgba(0, 0, 0, 0) 20%, rgba(0, 0, 0, 0) 80%, rgba(0, 0, 0, 0.3) 100%);
}

/* 光晕蒙版 */
.mask-light {
  background: 
    radial-gradient(ellipse at 50% 50%, rgba(255, 255, 255, 0) 0%, rgba(255, 255, 255, 0) 40%, rgba(0, 0, 0, 0.2) 100%);
}

.custom-bg-preview {
  margin-top: 16rpx;
  position: relative;
  width: 200rpx;
  height: 140rpx;
  border-radius: 12rpx;
  overflow: hidden;
}

.preview-image {
  width: 100%;
  height: 100%;
}

.remove-btn {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  width: 40rpx;
  height: 40rpx;
  background: rgba(0, 0, 0, 0.5);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 24rpx;
}

/* ==================== 卡片预览 ==================== */
.card-preview-wrapper {
  width: 100%;
  height: 280rpx; /* 按会员卡比例 1.585:1 */
  border-radius: 20rpx;
  position: relative;
  overflow: hidden;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.15);
}

/* 背景层 */
.card-preview-bg {
  position: absolute;
  inset: 0;
  z-index: 1;
}

.card-preview-bg.bg-luxury {
  background: 
    radial-gradient(circle at 30% 30%, rgba(255, 215, 0, 0.3) 0%, transparent 50%),
    linear-gradient(135deg, #1a1a1a 0%, #2d2d2d 20%, #FFD700 50%, #FFA500 70%, #1a1a1a 100%);
}

.card-preview-bg.bg-simple {
  background: linear-gradient(135deg, #E0F7FA 0%, #B2EBF2 50%, #81D4FA 100%);
}

.card-preview-bg.bg-tech {
  background: 
    linear-gradient(45deg, rgba(0, 255, 255, 0.3) 0%, transparent 50%),
    linear-gradient(135deg, #00F5FF 0%, #0EA5E9 30%, #7928CA 70%, #4C1D95 100%);
}

.card-preview-bg.bg-retro {
  background: 
    linear-gradient(135deg, #D946EF 0%, #C026D3 30%, #B45309 70%, #92400E 100%);
}

.card-preview-bg.bg-dream {
  background: 
    radial-gradient(circle at 20% 50%, rgba(240, 171, 252, 0.4) 0%, transparent 50%),
    radial-gradient(circle at 80% 50%, rgba(167, 192, 255, 0.4) 0%, transparent 50%),
    linear-gradient(135deg, #F0ABFC 0%, #DDD6FE 25%, #A7C0FF 50%, #FBCFE8 75%, #FFC1E9 100%);
}

.card-preview-bg.bg-default {
  background: linear-gradient(135deg, #3C8CE7 0%, #55ace6 100%);
}

/* 蒙版层 */
.card-preview-mask {
  position: absolute;
  inset: 0;
  z-index: 2;
}

/* 内容层 */
.card-preview-content {
  position: absolute;
  inset: 0;
  z-index: 3;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.preview-name {
  font-size: 36rpx;
  font-weight: 600;
  color: #fff;
  margin-bottom: 12rpx;
}

.preview-type {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.9);
  background: rgba(0, 0, 0, 0.2);
  padding: 6rpx 20rpx;
  border-radius: 20rpx;
}

/* ==================== 预设项目 ==================== */
.preset-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.preset-item {
  background: #fafafa;
  border-radius: 12rpx;
  padding: 16rpx;
}

.preset-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.preset-index {
  font-size: 26rpx;
  font-weight: 500;
  color: #3C8CE7;
}

.preset-remove {
  padding: 8rpx 16rpx;
}

.preset-remove text {
  font-size: 24rpx;
  color: #ff4d4f;
}

.preset-form {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.preset-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.preset-label {
  font-size: 26rpx;
  color: #666;
  width: 160rpx;
  flex-shrink: 0;
}

.preset-input {
  flex: 1;
  height: 72rpx;
  padding: 0 20rpx;
  background: #fff;
  border-radius: 8rpx;
  font-size: 28rpx;
  color: #333;
  border: 1rpx solid #e8e8e8;
}

.add-preset-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 88rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  margin-top: 16rpx;
  border: 2rpx dashed #ccc;
}

.add-icon {
  font-size: 36rpx;
  color: #3C8CE7;
  margin-right: 8rpx;
}

.add-preset-btn text:last-child {
  font-size: 28rpx;
  color: #3C8CE7;
}

/* ==================== 通知选项 ==================== */
.notify-options {
  display: flex;
  gap: 16rpx;
}

.notify-option {
  flex: 1;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #f5f5f5;
  border-radius: 12rpx;
  border: 2rpx solid transparent;
  transition: all 0.2s ease;
}

.notify-option.active {
  background: #e3f2fd;
  border-color: #3C8CE7;
}

.notify-option text {
  font-size: 28rpx;
  color: #666;
}

.notify-option.active text {
  color: #3C8CE7;
  font-weight: 500;
}

/* ==================== 开关行 ==================== */
.switch-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.form-hint {
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
}

/* ==================== 底部占位 ==================== */
.bottom-placeholder {
  height: 160rpx;
}

/* ==================== 提交按钮 ==================== */
.submit-section {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  background: #fff;
  box-shadow: 0 -4rpx 16rpx rgba(0, 0, 0, 0.05);
}

.submit-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 96rpx;
  background: linear-gradient(150deg, #3C8CE7 20%, #55ace6 100%);
  border-radius: 48rpx;
  color: #fff;
  font-size: 32rpx;
  font-weight: 500;
  border: none;
  box-shadow: 0 8rpx 24rpx rgba(60, 140, 231, 0.4);
}

.submit-btn[disabled] {
  background: #ccc;
  box-shadow: none;
}

/* ==================== 上传进度条 ==================== */
.upload-progress-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.7);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 9999;
}

.progress-content {
  width: 600rpx;
  background: white;
  border-radius: 16rpx;
  padding: 40rpx;
}

.progress-title {
  font-size: 32rpx;
  font-weight: 600;
  text-align: center;
  margin-bottom: 24rpx;
  color: #333;
}

.progress-bar-container {
  width: 100%;
  height: 12rpx;
  background: #f0f0f0;
  border-radius: 6rpx;
  overflow: hidden;
  margin-bottom: 16rpx;
}

.progress-bar {
  height: 100%;
  background: linear-gradient(90deg, #3C8CE7, #5BA3F5);
  transition: width 0.3s;
}

.progress-text {
  font-size: 24rpx;
  color: #666;
  text-align: center;
}

