  .pattern-item {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12rpx;
    padding: 16rpx;
    border-radius: 12rpx;
    border: 2rpx solid transparent;
    transition: all 0.2s ease;
  }
  
  .pattern-item.selected {
    border-color: #3C8CE7;
    background: #e3f2fd;
  }
  
  .pattern-preview {
    width: 100%;
    height: 120rpx;
    border-radius: 8rpx;
    background: #f5f5f5;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }
  
  .pattern-preview image {
    width: 100%;
    height: 100%;
  }
  
  .pattern-preview.no-pattern {
    font-size: 28rpx;
    color: #999;
  }
  
  .pattern-name {
    font-size: 24rpx;
    color: #666;
  }
  
  .pattern-item.selected .pattern-name {
    color: #3C8CE7;
    font-weight: 500;
  }
  
  /* ==================== Canvas蒙版预览 ==================== */
  .mask-canvas-wrapper {
    width: 100%;
    position: relative;
    background: 
      repeating-conic-gradient(#f0f0f0 0% 25%, white 0% 50%) 
      50% / 20px 20px;
    border-radius: 12rpx;
    overflow: hidden;
    box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.1);
  }
  
  .mask-canvas-hidden {
    width: 100%;
    height: 320rpx;
    position: absolute;
    left: -9999rpx; /* 隐藏在屏幕外，仅用于绘制 */
    opacity: 0;
    pointer-events: none;
  }
  
  .mask-preview-image {
    width: 100%;
    height: auto; /* 高度自适应，保持图片原比例 */
    display: block;
  }
  
  .preview-placeholder {
    width: 100%;
    height: 320rpx;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #f5f5f5;
    color: #999;
    font-size: 28rpx;
  }
  
  .canvas-hint {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(255, 255, 255, 0.9);
    color: #999;
    font-size: 28rpx;
    pointer-events: none;
  }
  
  /* ==================== 底部操作按钮 ==================== */
  .bottom-actions {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    display: flex;
    gap: 16rpx;
    padding: 20rpx;
    background: #fff;
    box-shadow: 0 -4rpx 12rpx rgba(0, 0, 0, 0.08);
    z-index: 100;
  }
  
  .action-btn {
    flex: 1;
    height: 80rpx;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 12rpx;
    font-size: 28rpx;
    font-weight: 500;
    transition: all 0.2s ease;
  }
  
  .secondary-btn {
    background: #f5f5f5;
    color: #666;
  }
  
  .secondary-btn:active {
    background: #e0e0e0;
  }
  
  .primary-btn {
    background: linear-gradient(135deg, #3C8CE7 0%, #55ace6 100%);
    color: #fff;
    box-shadow: 0 4rpx 12rpx rgba(60, 140, 231, 0.3);
  }
  
  .primary-btn:active {
    opacity: 0.8;
  }
  
  .success-btn {
    background: linear-gradient(135deg, #4CAF50 0%, #66BB6A 100%);
    color: #fff;
    box-shadow: 0 4rpx 12rpx rgba(76, 175, 80, 0.3);
  }
  
  .success-btn:active {
    opacity: 0.8;
  }
  
  /* ==================== OSS结果 ==================== */
  .oss-result {
    background: #fff;
    border-radius: 16rpx;
    padding: 32rpx;
    margin-bottom: 20rpx;
    box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
  }
  
  .result-title {
    font-size: 32rpx;
    font-weight: 600;
    color: #4CAF50;
    margin-bottom: 20rpx;
  }
  
  .result-item {
    margin-bottom: 16rpx;
    display: flex;
    flex-direction: column;
    gap: 8rpx;
  }
  
  .result-label {
    font-size: 24rpx;
    color: #999;
  }
  
  .result-value {
    font-size: 26rpx;
    color: #333;
    word-break: break-all;
  }
  
  .result-value.small {
    font-size: 22rpx;
    color: #666;
  }
  
  /* ==================== 渐变方向选择 ==================== */
  .gradient-direction-group {
    display: flex;
    gap: 16rpx;
    justify-content: space-between;
  }
  
  .direction-item {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8rpx;
    padding: 12rpx;
    border-radius: 8rpx;
    background: #f5f5f5;
    transition: all 0.3s;
    cursor: pointer;
  }
  
  .direction-item.selected {
    background: #e3f2fd;
    border: 2rpx solid #3C8CE7;
  }
  
  .direction-preview {
    width: 100%;
    height: 80rpx;
    border-radius: 8rpx;
    border: 1rpx solid #ddd;
  }
  
  .direction-label {
    font-size: 24rpx;
    color: #666;
  }
  
  .direction-item.selected .direction-label {
    color: #3C8CE7;
    font-weight: 500;
  }
  
  /* ==================== 高级背景选择 ==================== */
  .advanced-bg-group {
    display: flex;
    gap: 16rpx;
    justify-content: space-between;
  }
  
  .advanced-bg-item {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8rpx;
    padding: 8rpx;
    border-radius: 8rpx;
    background: #f5f5f5;
    transition: all 0.3s;
    cursor: pointer;
  }
  
  .advanced-bg-item.selected {
    background: #e3f2fd;
    border: 2rpx solid #3C8CE7;
  }
  
  .advanced-bg-preview {
    width: 100%;
    height: 120rpx;
    border-radius: 8rpx;
    border: 1rpx solid #ddd;
  }
  
  .advanced-bg-name {
    font-size: 24rpx;
    color: #666;
  }
  
  .advanced-bg-item.selected .advanced-bg-name {
    color: #3C8CE7;
    font-weight: 500;
  }
  
  /* ==================== 自定义背景 ==================== */
  .custom-bg-container {
    display: flex;
    align-items: center;
    gap: 16rpx;
  }
  
  .custom-bg-preview {
    width: 120rpx;
    height: 120rpx;
    border-radius: 8rpx;
    border: 2rpx dashed #ddd;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #f5f5f5;
    overflow: hidden;
    cursor: pointer;
    transition: all 0.3s;
  }
  
  .custom-bg-preview:active {
    transform: scale(0.95);
  }
  
  .custom-bg-preview image {
    width: 100%;
    height: 100%;
  }
  
  .upload-icon {
    font-size: 48rpx;
    color: #999;
  }
  
  .change-bg-btn {
    flex: 1;
    height: 60rpx;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #3C8CE7;
    color: white;
    border-radius: 8rpx;
    font-size: 28rpx;
    transition: all 0.3s;
  }
  
  .change-bg-btn:active {
    background: #2b7ad4;
  }
  /* ==================== 预设项目 ==================== */
.preset-list {
    display: flex;
    flex-direction: column;
    gap: 16rpx;
  }
  
  .preset-item {
    background: #fafafa;
    border-radius: 12rpx;
    padding: 16rpx;
  }
  
  .preset-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 12rpx;
  }
  
  .preset-index {
    font-size: 26rpx;
    font-weight: 500;
    color: #3C8CE7;
  }
  
  .preset-remove {
    padding: 8rpx 16rpx;
  }
  
  .preset-remove text {
    font-size: 24rpx;
    color: #ff4d4f;
  }
  
  .preset-form {
    display: flex;
    flex-direction: column;
    gap: 12rpx;
  }
  
  .preset-row {
    display: flex;
    align-items: center;
    gap: 12rpx;
  }
  
  .preset-label {
    font-size: 26rpx;
    color: #666;
    width: 160rpx;
    flex-shrink: 0;
  }
  
  .preset-input {
    flex: 1;
    height: 72rpx;
    padding: 0 20rpx;
    background: #fff;
    border-radius: 8rpx;
    font-size: 28rpx;
    color: #333;
    border: 1rpx solid #e8e8e8;
  }
  
  .add-preset-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    height: 88rpx;
    background: #f5f5f5;
    border-radius: 12rpx;
    margin-top: 16rpx;
    border: 2rpx dashed #ccc;
  }
  
  .add-icon {
    font-size: 36rpx;
    color: #3C8CE7;
    margin-right: 8rpx;
  }
  
  .add-preset-btn text:last-child {
    font-size: 28rpx;
    color: #3C8CE7;
  }