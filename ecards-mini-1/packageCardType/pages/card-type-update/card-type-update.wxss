/* pages/card-type-update/card-type-update.wxss */
.page-container {
  min-height: 100vh;
  background: #f5f5f5;
  padding-top: 120rpx; /* 为吸顶Tab留出空间 */
  padding-bottom: 180rpx; /* 为底部按钮留出空间 */
  padding-left: 20rpx;
  padding-right: 20rpx;
  box-sizing: border-box;
}

/* ==================== Tab切换（吸顶） ==================== */
.tab-bar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  display: flex;
  background: white;
  padding: 16rpx 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.1);
  z-index: 1000;
}

.tab-item {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 20rpx 0;
  border-radius: 12rpx;
  transition: all 0.3s;
}

.tab-item.active {
  background: linear-gradient(150deg, #3C8CE7 20%, #55ace6 100%);
  color: white;
}

.tab-icon {
  font-size: 28rpx;
}

.tab-text {
  font-size: 26rpx;
  font-weight: 500;
}

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(10rpx); }
  to { opacity: 1; transform: translateY(0); }
}

/* ==================== 旧卡片展示 ==================== */
.old-card-section {
  background: white;
  border-radius: 16rpx;
  padding: 24rpx 20rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
  display: flex;
  justify-content: center;
  overflow: hidden;
}

.section-header {
  margin-bottom: 16rpx;
}

.section-title-text {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}

.section-hint {
  display: block;
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
}

/* ==================== 提交按钮区（置底） ==================== */
.submit-section {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: white;
  padding: 20rpx 30rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.1);
  z-index: 999;
}

.submit-section.design-submit {
  display: flex;
  gap: 20rpx;
}

.submit-section button {
  flex: 1;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: 500;
  border: none;
  background: linear-gradient(150deg, #3C8CE7 20%, #55ace6 100%);
  color: white;
  box-shadow: 0 8rpx 24rpx rgba(60, 140, 231, 0.4);
}

.submit-section button.secondary {
  background: linear-gradient(150deg, #667eea 20%, #764ba2 100%);
  box-shadow: 0 8rpx 24rpx rgba(102, 126, 234, 0.4);
}

.submit-section button[disabled] {
  background: #cccccc;
  color: #999999;
  box-shadow: none;
}

/* ==================== 卡片预览 ==================== */
.card-preview-wrapper {
  width: 100%;
  height: 280rpx;
  border-radius: 20rpx;
  position: relative;
  overflow: hidden;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.15);
}

.card-preview-bg {
  position: absolute;
  inset: 0;
  z-index: 1;
}

.card-preview-bg.bg-luxury {
  background: 
    radial-gradient(circle at 30% 30%, rgba(255, 215, 0, 0.3) 0%, transparent 50%),
    linear-gradient(135deg, #1a1a1a 0%, #2d2d2d 20%, #FFD700 50%, #FFA500 70%, #1a1a1a 100%);
}

.card-preview-bg.bg-simple {
  background: linear-gradient(135deg, #E0F7FA 0%, #B2EBF2 50%, #81D4FA 100%);
}

.card-preview-bg.bg-tech {
  background: 
    linear-gradient(45deg, rgba(0, 255, 255, 0.3) 0%, transparent 50%),
    linear-gradient(135deg, #00F5FF 0%, #0EA5E9 30%, #7928CA 70%, #4C1D95 100%);
}

.card-preview-bg.bg-retro {
  background: 
    linear-gradient(135deg, #D946EF 0%, #C026D3 30%, #B45309 70%, #92400E 100%);
}

.card-preview-bg.bg-dream {
  background: 
    radial-gradient(circle at 20% 50%, rgba(240, 171, 252, 0.4) 0%, transparent 50%),
    radial-gradient(circle at 80% 50%, rgba(167, 192, 255, 0.4) 0%, transparent 50%),
    linear-gradient(135deg, #F0ABFC 0%, #DDD6FE 25%, #A7C0FF 50%, #FBCFE8 75%, #FFC1E9 100%);
}

.card-preview-bg.bg-default {
  background: linear-gradient(135deg, #3C8CE7 0%, #55ace6 100%);
}

.card-preview-mask {
  position: absolute;
  inset: 0;
  z-index: 2;
}

.card-preview-mask.mask-radial {
  background: radial-gradient(circle at center, rgba(255, 255, 255, 0) 0%, rgba(0, 0, 0, 0.4) 100%);
}

.card-preview-mask.mask-linear {
  background: linear-gradient(180deg, rgba(0, 0, 0, 0.1) 0%, rgba(0, 0, 0, 0.3) 100%);
}

.card-preview-mask.mask-rect {
  background: 
    linear-gradient(90deg, rgba(0, 0, 0, 0.3) 0%, rgba(0, 0, 0, 0) 20%, rgba(0, 0, 0, 0) 80%, rgba(0, 0, 0, 0.3) 100%);
}

.card-preview-mask.mask-light {
  background: 
    radial-gradient(ellipse at 50% 50%, rgba(255, 255, 255, 0) 0%, rgba(255, 255, 255, 0) 40%, rgba(0, 0, 0, 0.2) 100%);
}

.card-preview-content {
  position: absolute;
  inset: 0;
  z-index: 3;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.preview-name {
  font-size: 36rpx;
  font-weight: 600;
  color: #fff;
  margin-bottom: 12rpx;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.3);
}

.preview-type {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.9);
  background: rgba(0, 0, 0, 0.2);
  padding: 6rpx 20rpx;
  border-radius: 20rpx;
}

/* ==================== 表单卡片 ==================== */
.form-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.card-title {
  display: flex;
  align-items: center;
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 32rpx;
  padding-bottom: 20rpx;
  border-bottom: 2rpx solid #f0f0f0;
}

.card-icon {
  font-size: 36rpx;
  margin-right: 12rpx;
}

.form-item {
  margin-bottom: 32rpx;
}

.form-item:last-child {
  margin-bottom: 0;
}

.form-item.required .form-label {
  position: relative;
}

.form-label {
  display: block;
  font-size: 28rpx;
  color: #666;
  margin-bottom: 16rpx;
  font-weight: 500;
}

.required-star {
  color: #ff4d4f;
  margin-left: 4rpx;
}

.form-input {
  width: 100%;
  height: 88rpx;
  padding: 0 24rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  font-size: 30rpx;
  color: #333;
  box-sizing: border-box;
}

.form-textarea {
  width: 100%;
  min-height: 160rpx;
  padding: 20rpx 24rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  font-size: 30rpx;
  color: #333;
  box-sizing: border-box;
}

/* 只读字段样式 */
.form-readonly {
  display: flex;
  align-items: center;
  height: 88rpx;
  padding: 0 24rpx;
  background: #f0f0f0;
  border-radius: 12rpx;
}

.readonly-icon {
  font-size: 32rpx;
  margin-right: 8rpx;
}

.readonly-value {
  font-size: 30rpx;
  color: #666;
  font-weight: 500;
}

.readonly-hint {
  font-size: 24rpx;
  color: #999;
  margin-left: 12rpx;
}

/* ==================== 单选组 ==================== */
.radio-group {
  display: flex;
  gap: 16rpx;
  flex-wrap: wrap;
}

.radio-item {
  flex: 1;
  min-width: 140rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #f5f5f5;
  border-radius: 12rpx;
  border: 2rpx solid transparent;
  font-size: 28rpx;
  color: #666;
  transition: all 0.2s ease;
}

.radio-item.active {
  background: #e3f2fd;
  border-color: #3C8CE7;
  color: #3C8CE7;
  font-weight: 500;
}

/* ==================== 底部操作按钮 ==================== */
.bottom-actions {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  gap: 20rpx;
  padding: 20rpx;
  background: #fff;
  box-shadow: 0 -4rpx 12rpx rgba(0, 0, 0, 0.08);
  z-index: 100;
}

.action-btn {
  flex: 1;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 12rpx;
  font-size: 32rpx;
  font-weight: 500;
  transition: all 0.2s ease;
}

.cancel-btn {
  background: #f5f5f5;
  color: #666;
}

.cancel-btn:active {
  background: #e0e0e0;
}

.submit-btn {
  background: linear-gradient(135deg, #3C8CE7 0%, #55ace6 100%);
  color: #fff;
  box-shadow: 0 4rpx 12rpx rgba(60, 140, 231, 0.3);
}

.submit-btn:active {
  opacity: 0.8;
}
