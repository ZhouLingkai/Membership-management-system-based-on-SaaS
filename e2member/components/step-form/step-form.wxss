/* components/step-form/step-form.wxss */

.step-form-container {
  width: 100%;
  padding: 30rpx 0;
  overflow: hidden;
  display: flex;
  flex-direction: column;
}

/* 固定头部区域 - 包含进度条和标题 */
.step-header {
  flex-shrink: 0;
  position: relative;
  z-index: 10;
  background: inherit;
}

/* 步骤进度条容器 */
.step-progress {
  padding: 0 40rpx;
  margin-bottom: 30rpx;
}

.step-items {
  display: flex;
  align-items: center;
  justify-content: space-between;
  position: relative;
}

/* 步骤项 */
.step-item {
  position: relative;
  z-index: 2;
  flex-shrink: 0;
}

/* 步骤圆圈 */
.step-circle {
  width: 55rpx;
  height: 55rpx;
  border-radius: 50%;
  background: #f0f0f0;
  border: 4rpx solid #e0e0e0;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  transition: all 0.3s ease;
}

/* 步骤数字 */
.step-number {
  font-size: 28rpx;
  color: #999;
  font-weight: 600;
  transition: all 0.3s ease;
}

/* 完成标记 */
.step-check {
  position: absolute;
  font-size: 32rpx;
  color: #fff;
  font-weight: bold;
}

/* 激活状态 */
.step-item.active .step-circle {
  background: linear-gradient(135deg, #267cc8 0%, #3197e4 100%);
  border-color: #267cc8;
  box-shadow: 0 4rpx 12rpx rgba(38, 124, 200, 0.3);
  transform: scale(1.1);
}

.step-item.active .step-number {
  color: #fff;
}

/* 已完成状态 */
.step-item.completed .step-circle {
  background: linear-gradient(135deg, #267cc8 0%, #3197e4 100%);
  border-color: #267cc8;
}

.step-item.completed .step-number {
  display: none;
}

/* 连接线 */
.step-line {
  flex: 1;
  height: 4rpx;
  background: #e0e0e0;
  margin: 0 -10rpx;
  position: relative;
  z-index: 1;
  transition: all 0.4s ease;
}

.step-line::after {
  content: '';
  position: absolute;
  left: 0;
  top: 0;
  height: 100%;
  width: 0;
  background: linear-gradient(90deg, #267cc8 0%, #3197e4 100%);
  transition: width 0.4s ease;
}

.step-line.completed::after {
  width: 100%;
}

/* 步骤标题容器 - 固定高度防止重叠 */
.step-title-wrapper {
  padding: 0 40rpx;
  margin-bottom: 30rpx;
  min-height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 步骤标题 */
.step-title {
  text-align: center;
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  line-height: 1.4;
  word-break: break-word;
}

/* 表单内容区域 */
.step-content {
  flex: 1;
  padding: 0 40rpx;
  min-height: 400rpx;
  position: relative;
  z-index: 1;
}

/* 单选按钮主题色 */
radio .wx-radio-input.wx-radio-input-checked {
  background-color: #3197e4 !important;
  border-color: #3197e4 !important;
}

radio .wx-radio-input.wx-radio-input-checked::before {
  color: #ffffff !important;
}
