<!-- components/step-form/step-form.wxml -->
<view class="step-form-container">
  <!-- 固定头部区域：步骤进度条 + 标题 -->
  <view class="step-header">
    <!-- 步骤进度条 -->
    <view class="step-progress">
      <view class="step-items">
        <block wx:for="{{steps}}" wx:key="index">
          <!-- 步骤圆圈 -->
          <view class="step-item {{currentStep === index ? 'active' : ''}} {{index < currentStep ? 'completed' : ''}}" 
                bindtap="onStepClick" 
                data-index="{{index}}">
            <view class="step-circle">
              <text class="step-number">{{index + 1}}</text>
              <view class="step-check" wx:if="{{index < currentStep}}">✓</view>
            </view>
          </view>
          
          <!-- 连接线 -->
          <view class="step-line {{index < currentStep ? 'completed' : ''}}" wx:if="{{index < steps.length - 1}}"></view>
        </block>
      </view>
    </view>

    <!-- 步骤标题 -->
    <view class="step-title-wrapper">
      <text class="step-title">{{steps[currentStep]}}</text>
    </view>
  </view>

  <!-- 表单内容区域 -->
  <view class="step-content">
    <slot></slot>
  </view>
</view>
